{%- render 'section-spacing-collapsing' -%}

<style>

  #shopify-section-{{ section.id }} .why-scanovus {
    text-align: center;
    gap: 0px;
  }

  #shopify-section-{{ section.id }} .why-scanovus__heading {
    margin: 0;
    font-size: 32px;
    line-height: 1.2;
    font-weight: 500;
    color: {{ section.settings.custom_color_1 }};
  }

  #shopify-section-{{ section.id }} .why-scanovus__subheading {
    margin: 12px auto 0;
    max-width: 610px;
    font-size: 14px;
    line-height: 1.3;
    color: {{ section.settings.custom_color_2 }};
  }

  #shopify-section-{{ section.id }} .why-scanovus__matrix-wrap {
    margin-top: 50px;
    overflow-x: auto;
  }

  #shopify-section-{{ section.id }} .why-scanovus__matrix {
    width: min(700px, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 25px;
    --why-row-height: 66px;
  }

  #shopify-section-{{ section.id }} .why-scanovus__col {
    display: grid;
    grid-auto-rows: var(--why-row-height);
  }

  #shopify-section-{{ section.id }} .why-scanovus__head {
    display: grid;
    align-items: center;
    text-align: center;
    font-size: 14px;
    line-height: 1.3;
    font-weight: 500;
    color: {{ section.settings.custom_color_3 }};
    padding: 31px 19px;
  }

  #shopify-section-{{ section.id }} .why-scanovus__feature {
    text-align: left;
    display: grid;
    align-items: center;
    min-height: var(--why-row-height);
    font-size: 14px;
    line-height: 1.3;
    color: {{ section.settings.custom_color_4 }};
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding-inline: 8px 18px;
  }

  #shopify-section-{{ section.id }} .why-scanovus__value {
    display: grid;
    place-items: center;
    min-height: var(--why-row-height);
    border-bottom: 1px solid rgb(var(--text-color) / 0.08);
    gap: 8px;
    margin: 0px 25px;
    padding: 16px 0px;
  }

  #shopify-section-{{ section.id }} .why-scanovus__value-icon {
    width: 24px;
    height: 24px;
    display: block;
  }

  #shopify-section-{{ section.id }} .why-scanovus__mobile-label {
    margin: 0;
    display: none;
    font-size: 12px;
    line-height: 1.25;
    color: rgb(var(--text-color) / 0.8);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .why-scanovus__machine-col {
    border-radius: 14px;
    padding: 1px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.45) 0%, rgba(247, 245, 242, 0) 100%);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .why-scanovus__machine-inner {
    border-radius: inherit;
    background: rgb(var(--background));
    display: grid;
    grid-auto-rows: var(--why-row-height);
  }

  #shopify-section-{{ section.id }} .why-scanovus__machine-inner .why-scanovus__value:last-child,
  #shopify-section-{{ section.id }} .why-scanovus__traditional-col .why-scanovus__value:last-child,
  #shopify-section-{{ section.id }} .why-scanovus__labels-col .why-scanovus__feature:last-child {
    border-bottom: 0;
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .why-scanovus__heading {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__subheading {
      font-size: 18px;
      max-width: 640px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__matrix {
      min-width: 0;
      width: 100%;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      --why-row-height: 80px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__labels-col {
      display: none;
    }

    #shopify-section-{{ section.id }} .why-scanovus__head {
      font-size: 14px;
      padding: 8px 8px 4px;
      min-height: 64px;
      align-items: center;
      font-weight: 500;
      color: {{ section.settings.custom_color_5 }};
    }

    #shopify-section-{{ section.id }} .why-scanovus__value {
      min-height: 62px;
      align-content: center;
      justify-items: center;
      gap: 6px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__mobile-label {
      display: block;
    }
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .why-scanovus {
      padding: 35px 17px;
      background: {{ section.settings.custom_background_6 }};
      border-radius: 12px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__subheading {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__matrix-wrap {
      margin-top: 34px;
    }

    #shopify-section-{{ section.id }} .why-scanovus__value {
      min-height: unset;
    }

    #shopify-section-{{ section.id }} .why-scanovus__machine-inner {
      background: {{ section.settings.custom_background_7 }};
    }
  }

</style>

{% assign titles = product.metafields.custom.comparison_texts.value %}
{% assign list = product.metafields.custom.comparison_list.value %}
{%  assign blocks = list.comparison_list.value %}
{% if titles != blank and blocks != blank %}
<div {% render 'section-properties' %}>
  <div class="section-stack why-scanovus">
    {%- if titles.heading != blank -%}
      <h2 class="h2 why-scanovus__heading">{{ titles.heading | escape }}</h2>      
    {%- endif -%}
    {%- if titles.subheading != blank -%}
      <p class="why-scanovus__subheading">{{ titles.subheading | escape }}</p>
    {%- endif -%}

    <div class="why-scanovus__matrix-wrap">
      <div class="why-scanovus__matrix">
        <div class="why-scanovus__labels-col why-scanovus__col">
          <div class="why-scanovus__head" aria-hidden="true"></div>
          {%- for block in blocks -%}
            <div class="why-scanovus__feature" {{ block.shopify_attributes }}>{{ block.feature | escape }}</div>
          {%- endfor -%}
        </div>

        <div class="why-scanovus__machine-col">
          <div class="why-scanovus__machine-inner">
            <div class="why-scanovus__head">{{ titles.machine_column_title | escape }}</div>
            {%- for block in blocks -%}
              <div class="why-scanovus__value">
                {%- if block.machine_has_this -%}
                  <svg class="why-scanovus__value-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                    <path d="M12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12C0 5.37258 5.37258 0 12 0ZM10.5996 14.5186L7.37305 11.293L5.95898 12.707L10.7334 17.4814L11.4346 16.6406L18.1016 8.64062L16.5645 7.35938L10.5996 14.5186Z" fill="#19AF11"></path>
                  </svg>
                {%- else -%}
                  <svg class="why-scanovus__value-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="12" fill="#D92626"></circle>
                    <path d="M8 8L16 16M16 8L8 16" stroke="white" stroke-width="2" stroke-linecap="round"></path>
                  </svg>
                {%- endif -%}
                <p class="why-scanovus__mobile-label">{{ block.machine_mobile_label | default: block.feature | escape }}</p>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="why-scanovus__traditional-col why-scanovus__col">
          <div class="why-scanovus__head">{{ titles.traditional_column_title | escape }}</div>
          {%- for block in blocks -%}
            <div class="why-scanovus__value">
              {%- if block.traditional_has_this -%}
                <svg class="why-scanovus__value-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <path d="M12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12C0 5.37258 5.37258 0 12 0ZM10.5996 14.5186L7.37305 11.293L5.95898 12.707L10.7334 17.4814L11.4346 16.6406L18.1016 8.64062L16.5645 7.35938L10.5996 14.5186Z" fill="#19AF11"></path>
                </svg>
              {%- else -%}
                <svg class="why-scanovus__value-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="12" fill="#D92626"></circle>
                  <path d="M8 8L16 16M16 8L8 16" stroke="white" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              {%- endif -%}
              <p class="why-scanovus__mobile-label">{{ block.traditional_mobile_label | default: block.settings.feature | escape }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}
{% schema %}
{
  "name": "Product why comparison",
  "class": "shopify-section--product-why-comparison",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Scanovus?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether it's Monday morning rush, a last-minute outfit prep, or keeping shirts crisp for work - the Scanovus Automatic Ironing Machine makes it effortless."
    },
    {
      "type": "text",
      "id": "machine_title",
      "label": "Machine column title",
      "default": "Scanovus Automatic Ironing Machine"
    },
    {
      "type": "text",
      "id": "traditional_title",
      "label": "Traditional column title",
      "default": "Traditional Ironing"
    },
    {
      "type": "header",
      "content": "Custom Added Colors"
    },
    {
      "type": "color",
      "id": "custom_color_1",
      "label": "Why scanovus  heading Color",
      "default": "rgba(7, 7, 7, 1)"
    },
    {
      "type": "color",
      "id": "custom_color_2",
      "label": "Why scanovus  subheading Color",
      "default": "rgba(0, 0, 0, 0.85)"
    },
    {
      "type": "color",
      "id": "custom_color_3",
      "label": "Why scanovus  head Color",
      "default": "rgba(0, 0, 0, 0.85)"
    },
    {
      "type": "color",
      "id": "custom_color_4",
      "label": "Why scanovus  feature Color",
      "default": "rgba(0, 0, 0, 0.85)"
    },
    {
      "type": "color",
      "id": "custom_color_5",
      "label": "Why scanovus  head Color",
      "default": "rgba(0, 0, 0, 0.85)"
    },
    {
      "type": "color",
      "id": "custom_background_6",
      "label": "Why scanovus Color",
      "default": "rgba(247, 245, 242, 1)"
    },
    {
      "type": "color",
      "id": "custom_background_7",
      "label": "Why scanovus  machine inner Color",
      "default": "rgba(247, 245, 242, 1)"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Hands-free drying & ironing"
        },
        {
          "type": "text",
          "id": "machine_label",
          "label": "Machine mobile label"
        },
        {
          "type": "text",
          "id": "traditional_label",
          "label": "Traditional mobile label"
        },
        {
          "type": "checkbox",
          "id": "machine_ok",
          "label": "Machine has this",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "traditional_ok",
          "label": "Traditional has this",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product why comparison",
      "category": "Product",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
