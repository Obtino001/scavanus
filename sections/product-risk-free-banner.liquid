{%- render 'section-spacing-collapsing' -%}

<style>

  #shopify-section-{{ section.id }} .risk-free-banner {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    min-height: 420px;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__image,
  #shopify-section-{{ section.id }} .risk-free-banner__image img,
  #shopify-section-{{ section.id }} .risk-free-banner__image .placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__image .risk-free-banner__image-mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__image .risk-free-banner__image-desktop {
    display: block;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__card {
    position: absolute;
    right: 33px;
    bottom: 27px;
    width: min(600px, calc(100% - 32px));
    background: {{ section.settings.custom_background_1 }};
    border-radius: 12px;
    padding: 42px 48px;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__heading {
    margin: 0;
    font-size: 24px;
    line-height: 1.3;
    font-weight: 500;
    color: {{ section.settings.custom_color_2 }};
  }

  #shopify-section-{{ section.id }} .risk-free-banner__icon {
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__icon img {
    display: block;
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__icon img.risk-free-banner__icon-mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__icon-desktop {
    display: block;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__text {
    margin-top: 12px;
    font-size: 14x;
    line-height: 1.3;
    color: {{ section.settings.custom_color_3 }};
  }

  #shopify-section-{{ section.id }} .risk-free-banner__button {
    margin-top: 33px;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__button .button {
    width: 100%;
    justify-content: center;    
    border-radius: 999px;
    background: {{ section.settings.custom_background_4 }};
    color: {{ section.settings.custom_color_5 }};
    box-shadow: none;
    padding: 20px;
    font-size: 16px;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .risk-free-banner__meta {
    margin-top: 19px;
    text-align: center;
    font-size: 12px;
    font-weight: 400;
    color: {{ section.settings.custom_color_6 }};
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .risk-free-banner {
      min-height: unset;
      aspect-ratio: 382 / 584;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__card {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      width: calc(100% - 24px);
      text-align: center;
      padding: 34px 24px;
      bottom: 15px;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__text {
      display: none;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__image .risk-free-banner__image-mobile {
      display: block;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__image .risk-free-banner__image-desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__icon {
      display: flex;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__icon img.risk-free-banner__icon-mobile {
      display: block;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__icon-desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .risk-free-banner__heading {
      display: flex;
      flex-direction: column;
    }
    #shopify-section-{{ section.id }} .risk-free-banner__heading .sub {
      font-size: 18px;
    }
    #shopify-section-{{ section.id }} .risk-free-banner__button {
      margin-top: 19px;
    }
    #shopify-section-{{ section.id }} .risk-free-banner__meta {
      margin-top: 14px;
      font-size: 12px;
    }
  }

</style>

{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <div class="risk-free-banner">
      {%- liquid
        capture current_market
          render 'block-market-check', block: section, return_market: true
        endcapture

        assign section_image = section.settings.image
        assign section_mobile_image = section.settings.mobile_image
        assign section_icon = section.settings.icon
        assign section_mobile_icon = section.settings.mobile_icon

        if current_market contains 'us_ca_mx'
          assign section_image = section.settings.image_us_ca_mx | default: section_image
          assign section_mobile_image = section.settings.mobile_image_us_ca_mx | default: section_mobile_image
          assign section_icon = section.settings.icon_us_ca_mx | default: section_icon
          assign section_mobile_icon = section.settings.mobile_icon_us_ca_mx | default: section_mobile_icon
        endif
      -%}

   <div class="risk-free-banner__image">
        {%- if section_mobile_image != blank -%}
          {{ section_mobile_image | image_url: width: 1200 | image_tag: class: 'risk-free-banner__image-mobile', loading: 'lazy', widths: '500,700,900,1200', sizes: '100vw', alt: section.settings.heading | escape }}
          {%- assign desktop_image = section_image | default: section_mobile_image -%}
          {{ desktop_image | image_url: width: 2200 | image_tag: class: 'risk-free-banner__image-desktop', loading: 'lazy', widths: '900,1200,1500,1800,2200', sizes: '(max-width: 999px) 100vw, 1200px', alt: section.settings.heading | escape }}
        {%- elsif section_image != blank -%}
          {{ section_image | image_url: width: 2200 | image_tag: loading: 'lazy', widths: '900,1200,1500,1800,2200', sizes: '(max-width: 999px) 100vw, 1200px', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>

      <div class="risk-free-banner__card">
        {%- if section_mobile_icon != blank or section_icon != blank -%}
          <div class="risk-free-banner__icon">
            {%- if section_mobile_icon != blank -%}
              {{ section_mobile_icon | image_url: width: 72 | image_tag: class: 'risk-free-banner__icon-mobile', loading: 'lazy', widths: '36,48,72', sizes: '36px', alt: section.settings.heading | strip_html | escape }}
              {%- assign desktop_icon = section_icon | default: section_mobile_icon -%}
              {{ desktop_icon | image_url: width: 72 | image_tag: class: 'risk-free-banner__icon-desktop', loading: 'lazy', widths: '36,48,72', sizes: '36px', alt: section.settings.heading | strip_html | escape }}
            {%- else -%}
              {{ section_icon | image_url: width: 72 | image_tag: class: 'risk-free-banner__icon-desktop', loading: 'lazy', widths: '36,48,72', sizes: '36px', alt: section.settings.heading | strip_html | escape }}
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="h2 risk-free-banner__heading"><span></span><span class="sub">{{ section.settings.heading }}</span></h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="risk-free-banner__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          <div class="risk-free-banner__button">
            <a href="{{ section.settings.button_url | default: '#' }}" class="button button--xl">
              {{ section.settings.button_text | escape }}
            </a>
          </div>
        {%- endif -%}
        {%- if section.settings.meta_text != blank -%}
          <p class="risk-free-banner__meta">{{ section.settings.meta_text | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Product risk free banner",
  "class": "shopify-section--product-risk-free-banner",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "market_visibility",
      "label": "Market visibility",
      "options": [
        {
          "value": "all",
          "label": "Global (All Markets)"
        },
        {
          "value": "denmark",
          "label": "Denmark Only"
        },
        {
          "value": "us_ca_mx",
          "label": "US, CA & MX Only"
        },
        {
          "value": "global_excluding_us_ca_mx",
          "label": "Global (Exclude US, CA & MX)"
        }
      ],
      "default": "all"
    },
    {
      "type": "checkbox",
