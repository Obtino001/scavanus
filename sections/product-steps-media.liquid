{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} .product-steps-media {
    background: rgba(247, 245, 242, 1);
    border-radius: 14px;    
    display: grid;
    padding: 40px;
    border-radius: 12px;
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .product-steps-media__layout {
    display: grid;
    gap: 26px;
  }

  #shopify-section-{{ section.id }} .product-steps-media__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    padding-left: 30px;
  }

  #shopify-section-{{ section.id }} .product-steps-media__heading {
    margin: 0 0 60px;
    font-size: 32px;
    line-height: 1.3;
    font-weight: 500;
    color: rgba(7, 7, 7, 1);
  }

  #shopify-section-{{ section.id }} .product-steps-media__steps {
    display: grid;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .product-steps-media__step {
    position: relative;
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    column-gap: 22px;
    align-items: start;
    text-align: left;
    border: 0;
    background: transparent;
    padding: 0 0 18px;
    color: inherit;
    width: 100%;
    cursor: pointer;
    padding-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .product-steps-media__step:last-child {
    padding-bottom: 0;
  }
  #shopify-section-{{ section.id }} .product-steps-media__step-marker {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid #000;
    display: grid;
    place-items: center;
    font-size: 20px;
    line-height: 1;
    color: #000;
    background: transparent;
    transition: background-color 0.28s ease, border-color 0.28s ease, color 0.28s ease, transform 0.28s ease;
  }

  #shopify-section-{{ section.id }} .product-steps-media__step:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 23px;
    top: 50px;
    bottom: 2px;
    width: 1px;
    background-image: url("data:image/svg+xml,%3Csvg width='1' height='22' viewBox='0 0 1 22' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.5 0V22' stroke='black' stroke-opacity='0.87' stroke-dasharray='5 5'/%3E%3C/svg%3E");
    background-repeat: repeat-y;
    background-position: center center;
    background-size: 1px 22px;
    background-repeat: no-repeat;
  }

  #shopify-section-{{ section.id }} .product-steps-media__step-title {
    margin: 4px 0 4px;
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
    color: rgba(72, 72, 72, 1);
    transition: color 0.28s ease;
  }

  #shopify-section-{{ section.id }} .product-steps-media__step-text {
    margin: 0;
    font-size: 14px;
    line-height: 1.3;
    color: rgba(72, 72, 72, 1);
    transition: color 0.28s ease;
  }

  #shopify-section-{{ section.id }} .product-steps-media__step.is-active .product-steps-media__step-marker {
    background: rgb(var(--text-color));
    border-color: rgb(var(--text-color));
    color: rgb(var(--background));
    transform: scale(1.04);
  }

  #shopify-section-{{ section.id }} .product-steps-media__step.is-active .product-steps-media__step-title {
    color: rgb(var(--text-color));
  }

  #shopify-section-{{ section.id }} .product-steps-media__step.is-active .product-steps-media__step-text {
    color: rgb(var(--text-color) / 0.8);
  }

  #shopify-section-{{ section.id }} .product-steps-media__media {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: rgb(var(--text-color) / 0.08);
    opacity: 1;
    transition: opacity 0.25s ease;
  }

  #shopify-section-{{ section.id }} .product-steps-media__media.is-switching {
    opacity: 0.35;
  }

  #shopify-section-{{ section.id }} .product-steps-media__media img,
  #shopify-section-{{ section.id }} .product-steps-media__media video,
  #shopify-section-{{ section.id }} .product-steps-media__media iframe,
  #shopify-section-{{ section.id }} .product-steps-media__media .placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border: 0;
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .product-steps-media {
      padding: 0 0;
      background: transparent;
    }

    #shopify-section-{{ section.id }} .product-steps-media__layout {
      gap: 0;
    }

    #shopify-section-{{ section.id }} .product-steps-media__content {
      display: contents;
      padding-left: 0;
    }

    #shopify-section-{{ section.id }} .product-steps-media__heading {
      order: 1;
      text-align: center;
      font-size: 24px;
      margin-bottom: 19px;
    }

    #shopify-section-{{ section.id }} .product-steps-media__step:not(:last-child)::after {
      content: none;
    }

    #shopify-section-{{ section.id }} .product-steps-media__step {
      padding: 19px 12px !important;
    }

    #shopify-section-{{ section.id }} .product-steps-media__step-title {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .product-steps-media__step-text {
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .product-steps-media__step:nth-child(2),
    #shopify-section-{{ section.id }} .product-steps-media__step:nth-child(4) {
      background: rgba(247, 245, 242, 1);
      border-radius: 12px;      
    }

    #shopify-section-{{ section.id }} .product-steps-media__media {
      order: 2;
      margin-bottom: 14px;
      aspect-ratio: 382 / 264;
    }

    #shopify-section-{{ section.id }} .product-steps-media__steps {
      order: 3;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .product-steps-media__step {
      padding-bottom: 64px;
    }

    #shopify-section-{{ section.id }} .product-steps-media__layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      align-items: start;
      gap: 28px;
    }

    #shopify-section-{{ section.id }} .product-steps-media__media {
      position: sticky;
      top: calc(var(--sticky-area-height) + 24px);
    }
  }
</style>
{%- liquid
  capture market_code
    render 'block-market-check', block: section, return_market: true
  endcapture
  assign market_code = market_code | strip

  assign steps_meta = nil
  if market_code == 'us_ca_mx' and product.metafields.custom.product_step_medias_us_ca_mx.value != blank
    assign steps_meta = product.metafields.custom.product_step_medias_us_ca_mx.value
  else
    assign steps_meta = product.metafields.custom.product_step_medias.value
  endif

  if steps_meta != blank
    assign stepslist = steps_meta.step_medias.value
    assign is_meta = true
    assign heading = steps_meta.heading | default: section.settings.heading
  else
    assign stepslist = section.blocks
    assign is_meta = false
    assign heading = section.settings.heading
  endif
-%}

{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
{% if heading != blank and stepslist.size > 0 %}
  
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <steps-media class="product-steps-media" data-section-id="{{ section.id }}">
      <div class="product-steps-media__layout">
        <div class="product-steps-media__content">
          {%- if heading != blank -%}
            <h2 class="h2 product-steps-media__heading">{{ heading | escape }}</h2>
          {%- endif -%}

          <div class="product-steps-media__steps">
            {%- for block in stepslist -%}
              {%- liquid
                if is_meta
                  assign step_title = block.title.value | default: block.title
                  assign step_text = block.text.value | default: block.text
                  assign item_attributes = ''
                else
                  assign step_title = block.settings.title
                  assign step_text = block.settings.text
                  assign item_attributes = block.shopify_attributes
                endif
              -%}
              <button type="button" class="product-steps-media__step {% if forloop.first %}is-active{% endif %}" data-step-index="{{ forloop.index0 }}" {{ item_attributes }}>
                <span class="product-steps-media__step-marker">{{ forloop.index }}</span>
                <span>
                  {%- if step_title != blank -%}
                    <p class="product-steps-media__step-title">{{ step_title | escape }}</p>
                  {%- endif -%}
                  {%- if step_text != blank -%}
                    <p class="product-steps-media__step-text">{{ step_text | escape }}</p>
                  {%- endif -%}
                </span>
              </button>
            {%- endfor -%}
          </div>
        </div>

        <div class="product-steps-media__media" data-step-media></div>
      </div>

      {%- for block in stepslist -%}
        <template data-step-media-template="{{ forloop.index0 }}">
          {%- liquid
            if is_meta
              assign step_video = block.video.value | default: block.video
              assign step_image = block.image.value | default: block.image
              assign step_title = block.title.value | default: block.title
            else
              assign step_video = block.settings.video
              assign step_image = block.settings.image
              assign step_title = block.settings.title
            endif
          -%}

          {%- if step_video != blank -%}
            {% assign video_url = step_video | file_url %}
            <video 
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            >
              <source src="{{ video_url }}" type="video/mp4">
            </video>
       {%- elsif step_image != blank -%}
  {{ step_image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '500,700,900,1100,1400,1800', sizes: '(max-width: 999px) 100vw, 52vw', alt: step_title | escape }}
{%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder' }}
          {%- endif -%}
        </template>
      {%- endfor -%}
    </steps-media>
  </div>
</div>

<script>
  (() => {
    const root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root || root.dataset.stepsMediaReady === 'true') return;
    root.dataset.stepsMediaReady = 'true';

    const section = root.querySelector('steps-media');
    const steps = Array.from(root.querySelectorAll('.product-steps-media__step'));
    const mediaHost = root.querySelector('[data-step-media]');
    if (!section || !steps.length || !mediaHost) return;

    let activeIndex = -1;
    let switchTimer = null;

    const mountMedia = (index) => {
      const template = root.querySelector(`[data-step-media-template="${index}"]`);
      if (!template) return;

      mediaHost.innerHTML = '';
      mediaHost.appendChild(template.content.cloneNode(true));

      const externalVideo = mediaHost.querySelector('[data-step-external-video]');
      if (externalVideo && externalVideo.dataset.src) {
        externalVideo.setAttribute('src', externalVideo.dataset.src);
      }

      const localVideo = mediaHost.querySelector('video');
      if (localVideo) {
        localVideo.currentTime = 0;
        localVideo.play().catch(() => {});
      }
    };

    const setActive = (index, immediate = false) => {
      if (index === activeIndex || index < 0 || index >= steps.length) return;
      activeIndex = index;

      steps.forEach((step, i) => step.classList.toggle('is-active', i === index));

      if (switchTimer) {
        clearTimeout(switchTimer);
        switchTimer = null;
      }

      if (immediate) {
        mountMedia(index);
        return;
      }

      mediaHost.classList.add('is-switching');
      switchTimer = window.setTimeout(() => {
        mountMedia(index);
        requestAnimationFrame(() => {
          mediaHost.classList.remove('is-switching');
        });
      }, 120);
    };

    setActive(0, true);

    steps.forEach((step, index) => {
      step.addEventListener('click', () => {
        setActive(index);
      });
    });
  })();
</script>
{% endif %}
{%- endif -%}
{% schema %}
{
  "name": "Product steps media",
  "class": "shopify-section--product-steps-media",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "market_visibility",
      "label": "Market visibility",
      "options": [
        { "value": "all", "label": "Global (All Markets)" },
        { "value": "denmark", "label": "Denmark Only" },
        { "value": "us_ca_mx", "label": "US, CA & MX Only" },
        { "value": "global_excluding_us_ca_mx", "label": "Global (Exclude US, CA & MX)" }
      ],
      "default": "all"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works, Simple & Effective"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Step description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "video_url",
          "id": "external_video_url",
          "accept": ["youtube", "vimeo"],
          "label": "External video URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product steps media",
      "category": "Storytelling",
      "blocks": [
        { "type": "step", "settings": { "title": "Hang a Damp Garment", "text": "Use straight from the wash, or lightly mist if dry." } },
        { "type": "step", "settings": { "title": "Adjust for Fit", "text": "Expand the inflatable shirt balloon to match size." } },
        { "type": "step", "settings": { "title": "Select Time & Heat", "text": "Choose settings on the easy-to-use panel." } },
        { "type": "step", "settings": { "title": "Relax While It Works", "text": "The machine dries and smooths your clothes with warm air - no effort from you." } }
      ]
    }
  ]
}
{% endschema %}
