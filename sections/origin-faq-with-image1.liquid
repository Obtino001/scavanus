{%- render 'section-spacing-collapsing' -%}


{%- for block in section.blocks -%}
  {%- render 'block-color-css', block: block -%}
{%- endfor -%}



{%- render 'section-color-css' -%}
<style>
  #shopify-section-{{ section.id }} .origin-faq-image {
    display: grid;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .origin-faq-image__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .origin-faq-image__heading {
    margin: 0;
    font-size: 32px;
    font-weight: 500;
    color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
  }
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle .circle-chevron {
    width: auto;
    height: auto;
    border-radius: 0;
    background: transparent;
    color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
  }
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle .circle-chevron svg {
    display: none;
  }
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle .circle-chevron::before {
    content: "+";
    display: block;
    font-size: 24px;
    line-height: 1;
    font-weight: 400;
    color: rgba(39, 39, 39, 1) !important;
  }
  #shopify-section-{{ section.id }} .origin-faq-image details[open].accordion .accordion__toggle .circle-chevron::before {
    content: "−";
  }
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle:hover .circle-chevron::before {
    color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
  }
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle:hover .circle-chevron,
  #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle:focus-visible .circle-chevron,
  #shopify-section-{{ section.id }} .origin-faq-image details[open].accordion .accordion__toggle .circle-chevron {
    background: transparent;
    color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
    border-color: transparent;
  }

  #shopify-section-{{ section.id }} .origin-faq-image__media {
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--text-color) / 0.06);
    min-height: 320px;
  }

  #shopify-section-{{ section.id }} .origin-faq-image__media img,
  #shopify-section-{{ section.id }} .origin-faq-image__media .placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.image_fit }};
    aspect-ratio: {{ section.settings.image_aspect_ratio | replace: ':', '/' }};
  }
  .origin-faq-image .accordion__toggle {
    padding: 24px 0px;
    font-size: 16px;
    font-weight: 400;
    color: {% render 'setting-color', value: section.settings.text_color, default: 'rgba(0, 0, 0, 0.85)' %};
  }
  .origin-faq-image  .accordion:first-child {
    border-block-start-width: 0px;
  }
  .origin-faq-image  .accordion:last-child {
    border-block-end-width: 0px;
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .origin-faq-image__heading {
      font-size: 24px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .origin-faq-image .accordion__toggle {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .origin-faq-image .accordion__content,
    #shopify-section-{{ section.id }} .origin-faq-image .accordion__content .prose {
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .origin-faq-image__media {
      display: none;
    }
    #shopify-section-{{ section.id }} .origin-faq-image__content {
      padding: 46px 16px 16px 16px;
      background: {{ section.settings.background | default: 'rgba(247, 245, 242, 1)' }};
      border-radius: 12px;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .origin-faq-image {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 40px;
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .origin-faq-image__media {
      min-height: 100%;
    }
  }
</style>
{%- liquid
  capture market_code
    render 'block-market-check', block: section, return_market: true
  endcapture
  assign market_code = market_code | strip

  assign data_meta = nil
  if market_code == 'us_ca_mx' and product.metafields.custom.faq_us_ca_mx.value != blank
    assign data_meta = product.metafields.custom.faq_us_ca_mx.value
  elsif market_code == 'eu_non_european' and product.metafields.custom.faq_eu_non.value != blank
    assign data_meta = product.metafields.custom.faq_eu_non.value
  elsif market_code == 'eu' and product.metafields.custom.faq_eu.value != blank
    assign data_meta = product.metafields.custom.faq_eu.value
  else
    assign data_meta = product.metafields.custom.faq.value
  endif

  if data_meta != blank
    assign faqs = data_meta.faq_itemss.value
    assign is_meta = true
    assign heading = data_meta.heading | default: section.settings.title
    assign main_image = data_meta.image.value | default: data_meta.image | default: section.settings.image
  else
    assign faqs = section.blocks
    assign is_meta = false
    assign heading = section.settings.title
    assign main_image = section.settings.image
  endif
-%}

{% if faqs.size > 0 %}
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <div class="origin-faq-image">
      <div class="origin-faq-image__content">
        {%- if heading != blank -%}
          <h2 class="h2 origin-faq-image__heading">{{ heading | escape }}</h2>
        {%- endif -%}

        <div {% render 'surface', class: 'origin-faq-image__list rounded', background_fallback: '' %}>
          {%- for block in faqs -%}
            {%- liquid
              if is_meta
                assign item_title = block.title.value | default: block.title
                assign item_content = block.content.value | default: block.content
                assign item_attributes = ''
              else
                assign item_title = block.settings.title
                assign item_content = block.settings.content
                assign item_attributes = block.shopify_attributes
              endif
            -%}
            {%- if item_title != blank and item_content != blank -%}
              {%- capture accordion_content -%}
                <div class="prose">{{ item_content }}</div>
              {%- endcapture -%}
              {%- render 'accordion', title: item_title, content: accordion_content, block: block -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="origin-faq-image__media">
        {%- if main_image != blank -%}
          {{ main_image | image_url: width: 22000 | image_tag: loading: 'lazy', widths: '700,900,1100,1400,1600,1800,2000,2200', sizes: '(max-width: 999px) 100vw, 50vw', alt: heading | escape }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{% endif %}
{% schema %}
{
