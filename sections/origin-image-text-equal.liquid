{%- render 'section-spacing-collapsing' -%}




{%- render 'section-color-css' -%}
<style>
  #shopify-section-{{ section.id }} .origin-image-text-equal {
    display: grid;
    gap: 16px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__content {
    background: {{ section.settings.content_background }};
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__heading {
    margin: 0;
    font-size: 40px;
    line-height: 1.15;
    font-weight: 500;
    font-family: var(--heading-font-family);
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__description {
    margin-top: 14px;
    max-width: 520px;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__description p {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
    color: rgb(var(--text-color) / 0.78);    
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__button {
    margin-top: 28px;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__button .button {
    min-height: 48px;
    padding-inline: 90px;
    border-radius: 999px;
    border: 1px solid rgb(var(--text-color));
    background: transparent;
    color: rgb(var(--text-color));
    box-shadow: none;
    font-size: 14px;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__button .button:hover,
  #shopify-section-{{ section.id }} .origin-image-text-equal__button .button:focus-visible {
    background: transparent;
    color: rgb(var(--text-color));
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__media {
    border-radius: 12px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .origin-image-text-equal__image {
    width: 100%;
    height: 100%;
    aspect-ratio: {% if section.settings.image_ratio == 'square' %}1 / 1{% elsif section.settings.image_ratio == 'landscape' %}714 / 578{% else %}3 / 4{% endif %};
    object-fit: cover;
    display: block;
    border-radius: 12px;
    max-height: 448px;
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .origin-image-text-equal__image {
      max-height: 243px;
    }
    #shopify-section-{{ section.id }} .origin-image-text-equal__media {
      order: 1;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal__content {
      order: 2;
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal__description p {
      font-size: 14px;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .origin-image-text-equal {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal--media-start .origin-image-text-equal__media {
      order: 1;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal--media-start .origin-image-text-equal__content {
      order: 2;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal--media-end .origin-image-text-equal__content {
      order: 1;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal--media-end .origin-image-text-equal__media {
      order: 2;
    }

    #shopify-section-{{ section.id }} .origin-image-text-equal__content {
      padding: 54px 56px;
    }
  }
</style>

{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <div class="origin-image-text-equal origin-image-text-equal--media-{{ section.settings.media_position }}">
      <div class="origin-image-text-equal__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="origin-image-text-equal__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="origin-image-text-equal__description">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <div class="origin-image-text-equal__button">
            {%- render 'button', content: section.settings.button_text, href: section.settings.button_url, style: 'outline', size: 'xl' -%}
          </div>
        {%- endif -%}
      </div>

      <div class="origin-image-text-equal__media">
        {%- liquid
          capture current_market
            render 'block-market-check', block: section, return_market: true
          endcapture

          assign section_image = section.settings.image

          if current_market contains 'us_ca_mx' and section.settings.image_us_ca_mx != blank
            assign section_image = section.settings.image_us_ca_mx
          endif
        -%}

        {%- if section_image != blank -%}
          {%- capture sizes -%}(max-width: 999px) calc(100vw - 40px), min(50vw, 780px){%- endcapture -%}
          {{ section_image | image_url: width: section_image.width | image_tag: class: 'origin-image-text-equal__image', sizes: sizes, widths: '500,700,900,1100,1300,1500,1800', loading: 'lazy', alt: section_image.alt | escape }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'origin-image-text-equal__image placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Origin image text equal",
  "class": "shopify-section--origin-image-text-equal",
  "tag": "section",
  "disabled_on": {
    "templates": [
      "password"
    ],
    "groups": [
      "header",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (Default/Denmark)"
    },
    {
      "type": "image_picker",
      "id": "image_us_ca_mx",
      "label": "Image (US, CA & MX)"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "landscape",
          "label": "Landscape (714:578)"
        },
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "portrait",
          "label": "Portrait (3:4)"
        }
      ],
      "default": "landscape"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Image position (desktop)",
      "options": [
        {
          "value": "start",
          "label": "Left"
        },
        {
          "value": "end",
          "label": "Right"
        }
      ],
      "default": "end"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the founders"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our vision is to be the market leader in the development of innovative products that streamline and simplify everyday routines.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "content_background",
      "label": "Content panel background",
      "default": "#f4f2f0"
    },
    {
      "type": "select",
      "id": "market_visibility",
      "label": "Market visibility",
      "options": [
        {
          "value": "all",
          "label": "Global (All Markets)"
        },
        {
          "value": "denmark",
          "label": "Denmark Only"
        },
        {
          "value": "us_ca_mx",
          "label": "US, CA & MX Only"
        },
        {
          "value": "global_excluding_us_ca_mx",
          "label": "Global (Exclude US, CA & MX)"
        }
      ],
      "default": "all"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading"
    },
    {
      "type": "color_background",
      "id": "heading_gradient",
      "label": "Heading gradient"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card/block background"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card/block text"
    }
  ],
  "presets": [
    {
      "name": "Origin image text equal",
      "category": "Image"
    }
  ]
}
{% endschema %}
