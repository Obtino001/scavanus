    (() => {
      function init() {
        const section = document.getElementById('shopify-section-{{ section.id }}') || document.querySelector('.origin-review-slider')?.closest('.shopify-section');
        if (!section) return;

        const items = section.querySelectorAll('.origin-review-slider__item');
      items.forEach((item) => {
        const content = item.querySelector('.origin-review-slider__content');
        const readMore = item.querySelector('[data-read-more]');
        const readLess = item.querySelector('[data-read-less]');
        if (!content || !readMore || !readLess) return;

        const toggle = () => {
          const isCollapsed = content.classList.contains('origin-review-slider__content--collapsed');
          if (isCollapsed) {
            content.classList.remove('origin-review-slider__content--collapsed');
            readMore.hidden = true;
            readLess.hidden = false;
          } else {
            content.classList.add('origin-review-slider__content--collapsed');
            readMore.hidden = false;
            readLess.hidden = true;
          }
        };

        readMore.addEventListener('click', toggle);
        readLess.addEventListener('click', toggle);

        readLess.hidden = true;
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    })();
  </script>
{%- endif -%}

