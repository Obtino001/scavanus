{% assign reviews = product.metafields.custom.reviews.value %}
{%- if reviews.size > 0 -%}
  {%- render 'section-spacing-collapsing' -%}

{%- render 'section-color-css' -%}

  {%- liquid
    assign review_card_bg = section.settings.card_background | default: section.settings.summary_card_background
  -%}

  {%- assign scroll_area_id = 'review-scroll-area-' | append: section.id -%}

  <style>
    #shopify-section-{{ section.id }} {
      --origin-review-slider-mobile-card-width: 82vw;
      --origin-review-slider-desktop-card-width: calc((100% - (var(--grid-gutter) * 2)) / 3);
    }

    #shopify-section-{{ section.id }} .origin-review-slider {
      display: grid;
      gap: 22px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__heading-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__heading {
      margin: 0;
      font-size: 24px;
      line-height: 1.25;
      font-weight: 500;
      max-width: 970px;
      color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
      font-family: var(--heading-font-family);
    }

    #shopify-section-{{ section.id }} .origin-review-slider__nav {
      display: none;
      align-items: center;
      gap: 20px;
      flex: 0 0 auto;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__nav .circle-button {
      width: 38px;
      height: 38px;
      min-width: 38px;
      min-height: 38px;
      color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
      background: transparent;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__nav .circle-button:hover,
    #shopify-section-{{ section.id }} .origin-review-slider__nav .circle-button:focus-visible {
      color: {% render 'setting-color', value: section.settings.heading_color, default: 'rgba(39, 39, 39, 1)' %};
      background: transparent;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__body {
      display: grid;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary {
      background: {% render 'setting-color', value: review_card_bg, default: 'rgba(247, 245, 242, 1)' %};
      border-radius: 12px;
      padding: 20px;
      min-height: 320px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 16px;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary-top {
      display: grid;
      gap: 10px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary-logo {
      max-width: 130px;
      height: auto;
      display: block;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary-rating {
      margin: 0;
      font-size: 20px;
      line-height: 1;
      font-weight: 500;
      color: #rgba(26, 26, 26, 1);
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary-meta {
      margin: 0;
      font-size: 14px;
      line-height: 1.3;
      color: rgba(26, 26, 26, 1);
      font-weight: 500;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__summary button {
      box-shadow: none;
      padding-top: 16px;
      padding-bottom: 16px;
      border: 1px solid rgba(0, 0, 0, 1);
      color: rgba(0, 0, 0, 1);
      font-size: 14px;
      line-height: 1;
      font-weight: 400;
      min-width: 176px;
      margin-top: 22px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__summary-cta {
      display: flex;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__reviews {
      min-width: 0;
      overflow: hidden;
      height: 100%;
      position: relative;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__carousel {
      height: 100%;
      min-height: 303px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__carousel .swiper-wrapper {
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__carousel .swiper-slide {
      width: var(--origin-review-slider-mobile-card-width);
      height: auto;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__item {
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-width: 0;
      padding-right: 36px;
      padding-top: 40px;
      padding-bottom: 40px;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__item .origin-review-slider__content-wrap {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__item .origin-review-slider__content {
      flex: 0 1 auto;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__item .origin-review-slider__author {
      margin-top: auto;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__stars {
      margin: 0;
      font-size: 14px;
      line-height: 1;
      letter-spacing: 0.08em;
      color: #00b67a;
      text-transform: uppercase;
      font-weight: 600;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__stars-image {
      width: auto;
      height: 18px;
      display: block;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__stars-svg {
      width: 79px;
      height: 15px;
      display: block;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__content {
      margin: 0;
      font-size: 14px;
      line-height: 1.3;
      color: {% render 'setting-color', value: section.settings.text_color, default: 'rgba(72, 72, 72, 1)' %};
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content {
      overflow: hidden;
      transition: max-height 0.35s ease;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content--collapsed {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      max-height: 3.9em;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content:not(.origin-review-slider__content--collapsed) {
      max-height: 2000px;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content--collapsed p {
      margin: 0 0 0.5em;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content--collapsed p:last-child {
      margin-bottom: 0;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__content p {
      font-size: 14px;
      line-height: 1.3;
      color: {% render 'setting-color', value: section.settings.text_color, default: 'rgba(72, 72, 72, 1)' %};
    }

    #shopify-section-{{ section.id }} .origin-review-slider__author {
      margin: 0;
      font-size: 16px;
      line-height: 1.3;
      font-weight: 500;
      color:rgba(72, 72, 72, 1);
    }

    #shopify-section-{{ section.id }} .origin-review-slider__read-toggle {
      font-size: 14px;
      margin-top: 10px;
      text-decoration: underline;
    }

    #shopify-section-{{ section.id }} .origin-review-slider__progress {
      position: absolute;
      bottom: 0px;
      left: 10px;
      width: 100%;
      z-index: 1;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__carousel {
      height: 100%;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__progress .scrollbar__buttons {
      display: none;
    }
    #shopify-section-{{ section.id }} .origin-review-slider__summary-cta .button {
      font-weight: 400;
    }
    @media screen and (max-width: 999px) {
      #shopify-section-{{ section.id }} {
        --origin-review-slider-mobile-card-width: calc((100% - 3px) / 1.3);
      }

      #shopify-section-{{ section.id }} .origin-review-slider__body {
        gap: 27px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__carousel {
        gap: 10px;
        padding-bottom: 32px;
      }
      

      #shopify-section-{{ section.id }} .origin-review-slider__heading-row {
        justify-content: center;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__heading {
        text-align: center;
        margin-inline: auto;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary,
      #shopify-section-{{ section.id }} .origin-review-slider__carousel {
        min-height: 0;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary {
        display: contents;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-top {
        order: 1;
        gap: 6px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-inline-rating {
        display: inline-flex;
        align-items: baseline;
        justify-content: center;
        gap: 8px;
        white-space: nowrap;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-inline-rating .origin-review-slider__summary-rating,
      #shopify-section-{{ section.id }} .origin-review-slider__summary-inline-rating .origin-review-slider__summary-meta {
        margin: 0;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-rating {
        font-size: 18px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-meta {
        font-size: 12px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-brand {
        display: none;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__reviews {
        order: 2;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__item {
        background: {% render 'setting-color', value: review_card_bg, default: 'rgba(247, 245, 242, 1)' %};
        border-radius: 12px;
        padding: 16px;
        gap: 14px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__item .origin-review-slider__content {
        flex: 1;
        min-height: 0;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__item .origin-review-slider__author {
        margin-top: auto;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__progress {
        margin-top: 30px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-cta {
        order: 3;
        display: flex;
        justify-content: center;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary-cta .button {
        width: auto;
        padding: 16px 70px;        
      }

      #shopify-section-{{ section.id }} .origin-review-slider__mobile-brand {
        order: 4;
        display: flex;
        justify-content: center;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__mobile-brand-mark {
        display: inline-flex;
        align-items: center;
        line-height: 1;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__mobile-brand-mark svg {
        width: 111px;
        height: auto;
        display: block;
      }
    }

    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} {
        --origin-review-slider-mobile-card-width: 48vw;
      }
    }

    @media screen and (min-width: 1000px) {
      #shopify-section-{{ section.id }} {
        --origin-review-slider-desktop-card-width: calc((100% - (var(--grid-gutter) * {{ section.settings.desktop_cards | minus: 1 }})) / {{ section.settings.desktop_cards }});
      }

      #shopify-section-{{ section.id }} .origin-review-slider__heading {
        font-size: 32px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__nav {
        display: inline-flex;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__body {
        grid-template-columns: minmax(0, 280px) minmax(0, 1fr);
        gap: 28px;
        align-items: start;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__summary {
        min-height: 320px;
        padding: 48px 48px;
      }

      #shopify-section-{{ section.id }} .origin-review-slider__carousel .swiper-slide {
        width: var(--origin-review-slider-desktop-card-width);
      }
    }
  </style>


  <div {% render 'section-properties' %}>
    <div class="section-stack">       
      <div class="origin-review-slider">
        <div class="origin-review-slider__heading-row">
          <h2 class="origin-review-slider__heading hidden md:block">{{ section.settings.heading | escape }}</h2>
          <h2 class="origin-review-slider__heading md:hidden">{{ section.settings.heading_mobile | default: section.settings.heading | escape }}</h2>

          <div aria-controls="{{ scroll_area_id }}" class="origin-review-slider__nav">
            <button type="button" class="circle-button ring group" aria-controls="{{ scroll_area_id }}" data-swiper-prev>
              <span class="sr-only">{{ 'general.accessibility.previous' | t }}</span>
              <span class="animated-arrow animated-arrow--reverse"></span>
            </button>

            <button type="button" class="circle-button ring group" aria-controls="{{ scroll_area_id }}" data-swiper-next>
              <span class="sr-only">{{ 'general.accessibility.next' | t }}</span>
              <span class="animated-arrow"></span>
            </button>
          </div>
        </div>

        <div class="origin-review-slider__body">
          <div class="origin-review-slider__summary">
            <div class="origin-review-slider__summary-top">
              {% comment %} <div class="origin-review-slider__summary-brand">
                {%- if section.settings.summary_logo != blank -%}
                  {{ section.settings.summary_logo | image_url: width: section.settings.summary_logo.width | image_tag: class: 'origin-review-slider__summary-logo', widths: '120,180,240', sizes: '130px', loading: 'lazy', alt: section.settings.summary_logo.alt | escape }}
                {%- elsif section.settings.summary_title != blank -%}
                  <p class="h5"><svg width="111" height="28" viewBox="0 0 111 28" fill="none" xmlns="http://www.w3.org/2000/svg">
