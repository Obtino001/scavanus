{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
{%- render 'section-spacing-collapsing' -%}

{%- render 'section-color-css' -%}


{%- assign has_popup_video = false -%}
{%- for block in section.blocks -%}
  {%- if block.settings.video != blank or block.settings.external_video_url != blank -%}
    {%- assign has_popup_video = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<style>
  #shopify-section-{{ section.id }} .origin-featured-video-popup {
    display: grid;
    gap: 24px;
    align-items: stretch;
    background: {{ section.settings.background | default: 'rgba(247, 245, 242, 1)' }};
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__content {
    background: {{ section.settings.content_background | default: 'rgba(247, 245, 242, 1)' }};
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__heading {
    margin: 0;
    font-size: 40px;
    line-height: 1.1;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__description {
    margin-top: 14px;
    max-width: 560px;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__description p {
    margin: 0;
    font-size: 16px;
    line-height: 1.3;    
  }
  #shopify-section-{{ section.id }} .button {
    box-shadow: unset;
    padding: 16px 49px;
    font-size: 14px;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .origin-featured-video-popup__button {
    margin-top: 24px;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__proof {
    margin-top: 52px;
    flex: 1;
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    justify-content: end;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__proof-text {
    margin: 0;
    font-size: 18px;
    line-height: 1.2;
    font-weight: 500;
    font-family: var(--heading-font-family);
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatars {
    margin-top: 16px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar {
    position: relative;
    width: 66px;
    height: 66px;
    border-radius: 999px;
    overflow: hidden;    
    padding: 0;
    background: transparent;
    cursor: default;
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar--button {
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;    
    color: #fff;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar-play svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__media {    
    border-radius: 12px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .origin-featured-video-popup__media img,
  #shopify-section-{{ section.id }} .origin-featured-video-popup__media video {
    aspect-ratio: 664 / 519;
  }
  #shopify-section-{{ section.id }} .origin-featured-video-popup__media--mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__image,
  #shopify-section-{{ section.id }} .origin-featured-video-popup__media video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
    padding: 24px;
    overflow-y: auto;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal[hidden] {
    display: none;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.65);
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-dialog {
    position: relative;
    width: fit-content;
    height: fit-content;
    max-width: min(420px, calc(100vw - 48px));
    max-height: calc(100vh - 48px);
    border-radius: 14px;
    overflow: hidden;
    background: {{ section.settings.background | default: \'#000\' }};
    box-shadow: 0 20px 60px rgb(0 0 0 / 0.4);
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 1;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 0;
    display: grid;
    place-items: center;
    background: rgb(0 0 0 / 0.6);
    color: #fff;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media {
    width: fit-content;
    height: fit-content;
    max-width: min(420px, calc(100vw - 48px));
    max-height: calc(100vh - 80px);
    display: block;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media video {
    width: auto;
    height: auto;
    max-width: min(420px, calc(100vw - 48px));
    max-height: calc(100vh - 80px);
    display: block;
    border: 0;
    object-fit: contain;
    vertical-align: top;
  }

  #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media iframe {
    width: min(420px, calc(100vw - 48px));
    aspect-ratio: 16 / 9;
    height: auto;
    max-height: calc(100vh - 80px);
    display: block;
    border: 0;
    vertical-align: top;
  }
  #shopify-section-{{ section.id }} video-media {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }
  @supports (height: 100dvh) {
    #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-dialog {
      max-height: calc(100dvh - 48px);
    }
    #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media,
    #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media video {
      max-height: calc(100dvh - 80px);
    }
    #shopify-section-{{ section.id }} .origin-featured-video-popup__modal-media iframe {
      max-height: calc(100dvh - 80px);
    }
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .origin-featured-video-popup__content {
      padding: 31px 13px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__heading {
      font-size: 24px;
      text-align: center;
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__description p {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__description {
      margin-top: 24px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__media--mobile {
      display: block;
      margin-top: 12px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__media--desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__avatar {
      width: 77px;
      height: 77px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__avatars {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      width: 100%;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .origin-featured-video-popup {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .origin-featured-video-popup__content {
      padding: 70px 48px 40px 48px;
    }
  }

</style>

{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <div class="origin-featured-video-popup">
      <div class="origin-featured-video-popup__content">
        <div>
          {%- if section.settings.heading != blank -%}
            <h2 class="h2 origin-featured-video-popup__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- liquid
            capture current_market
              render 'block-market-check', block: section, return_market: true
            endcapture

            assign section_video = section.settings.main_video
            assign section_image = section.settings.image

            if current_market contains 'us_ca_mx'
              if section.settings.video_us_ca_mx != blank
                assign section_video = section.settings.video_us_ca_mx
              endif
              if section.settings.image_us_ca_mx != blank
                assign section_image = section.settings.image_us_ca_mx
              endif
            endif
          -%}

          <a href="{{section.settings.button_url }}" style="display: flex;">
          <div class="origin-featured-video-popup__media origin-featured-video-popup__media--mobile">
            {%- if section_video != blank -%}
              <video-media autoplay style="--aspect-ratio: {{ section_video.aspect_ratio | default: '16/9' }}" style="height: 100%;">
                {{ section_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, preload: 'auto', image_size: '600x' }}
              </video-media>
            {%- elsif section_image != blank -%}
              {%- capture sizes -%}(max-width: 999px) calc(100vw - 40px), min(55vw, 900px){%- endcapture -%}
              {{ section_image | image_url: width: section_image.width | image_tag: class: 'origin-featured-video-popup__image', sizes: sizes, widths: '500,700,900,1100,1300,1500,1800', loading: 'lazy', alt: section_image.alt | escape }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'origin-featured-video-popup__image placeholder' }}
            {%- endif -%}
          </div>
          </a>

          {%- if section.settings.description != blank -%}
            <div class="origin-featured-video-popup__description">{{ section.settings.description }}</div>
          {%- endif -%}

          {%- if section.settings.button_text != blank -%}
            <div class="origin-featured-video-popup__button">
              {%- render 'button', content: section.settings.button_text, href: section.settings.button_url, style: 'outline', size: 'xl' -%}
            </div>
          {%- endif -%}
        </div>
        {%- if section.settings.proof_text != blank or section.blocks.size > 0 -%}
          <div class="origin-featured-video-popup__proof">
            {%- if section.settings.proof_text != blank -%}
              <p class="origin-featured-video-popup__proof-text">{{ section.settings.proof_text | escape }}</p>
            {%- endif -%}

            {%- if section.blocks.size > 0 -%}
              <div class="origin-featured-video-popup__avatars">
                {%- for block in section.blocks -%}
                  {%- capture is_block_visible -%}{%- render 'block-market-check', block: block -%}{%- endcapture -%}
                  {%- if is_block_visible contains 'false' -%}{%- continue -%}{%- endif -%}

                  {%- if block.settings.image != blank -%}
                  {%- liquid
                    capture current_market
                      render 'block-market-check', block: section, return_market: true
                    endcapture

                    assign block_video = block.settings.video

                    if current_market contains 'us_ca_mx' and block.settings.video_us_ca_mx != blank
                      assign block_video = block.settings.video_us_ca_mx
                    endif

                    assign block_has_video = false
                    if block_video != blank or block.settings.external_video_url != blank
                      assign block_has_video = true
                    endif
                  -%}

                    {%- if block_has_video -%}
                      <button type="button" class="origin-featured-video-popup__avatar origin-featured-video-popup__avatar--button" data-video-open data-video-template="origin-featured-video-template-{{ block.id }}" aria-label="{{ block.settings.alt | default: 'Play customer video' | escape }}" {{ block.shopify_attributes }}>
                        {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy', widths: '50,100', sizes: '50px', alt: block.settings.alt | escape }}
                        <span class="origin-featured-video-popup__avatar-play">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
                            <path d="M12.3564 5.156C13.7884 5.90402 13.7884 7.9534 12.3564 8.70143L2.926 13.6275C1.59443 14.3231 0 13.3571 0 11.8548V2.00263C0 0.500329 1.59443 -0.465657 2.926 0.229909L12.3564 5.156Z" fill="white"></path>
                          </svg>
                        </span>
                      </button>
                    {%- else -%}
                      <span class="origin-featured-video-popup__avatar" {{ block.shopify_attributes }}>
                        {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy', widths: '50,100', sizes: '50px', alt: block.settings.alt | escape }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      <a href="{{section.settings.button_url }}" style="display: flex;">
        <div class="origin-featured-video-popup__media origin-featured-video-popup__media--desktop">
          {%- if section_video != blank -%}
            <video-media autoplay style="--aspect-ratio: {{ section_video.aspect_ratio | default: '16/9' }}">
              {{ section_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, preload: 'auto', image_size: '1200x' }}
            </video-media>
          {%- elsif section_image != blank -%}
            {%- capture sizes -%}(max-width: 999px) calc(100vw - 40px), min(55vw, 900px){%- endcapture -%}
            {{ section_image | image_url: width: section_image.width | image_tag: class: 'origin-featured-video-popup__image', sizes: sizes, widths: '500,700,900,1100,1300,1500,1800', loading: 'lazy', alt: section_image.alt | escape }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'origin-featured-video-popup__image placeholder' }}
          {%- endif -%}
        </div>
      </a>
    </div>
  </div>

  {%- if has_popup_video -%}
    <div class="origin-featured-video-popup__modal" data-video-modal hidden>
      <button type="button" class="origin-featured-video-popup__modal-backdrop" data-video-close aria-label="{{ 'general.accessibility.close' | t | escape }}"></button>

      <div class="origin-featured-video-popup__modal-dialog" role="dialog" aria-modal="true" aria-label="Customer video popup">
        <button type="button" class="origin-featured-video-popup__modal-close" data-video-close aria-label="{{ 'general.accessibility.close' | t | escape }}">
          {%- render 'icon' with 'close', width: 16, height: 16 -%}
        </button>
        <div class="origin-featured-video-popup__modal-media" data-video-modal-media></div>
      </div>
    </div>

    {%- for block in section.blocks -%}
      {%- capture is_block_visible -%}{%- render 'block-market-check', block: block -%}{%- endcapture -%}
      {%- if is_block_visible contains 'false' -%}{%- continue -%}{%- endif -%}
      {%- if block.settings.video != blank or block.settings.external_video_url != blank -%}
        <template id="origin-featured-video-template-{{ block.id }}">
          {%- liquid
            capture current_market
              render 'block-market-check', block: section, return_market: true
            endcapture

            assign block_video = block.settings.video

            if current_market contains 'us_ca_mx' and block.settings.video_us_ca_mx != blank
              assign block_video = block.settings.video_us_ca_mx
            endif
          -%}
          {%- if block_video != blank -%}
            {{ block_video | video_tag: controls: true, autoplay: false, loop: false, muted: false, playsinline: true, preload: 'metadata', image_size: '1200x' }}
          {%- elsif block.settings.external_video_url != blank -%}
            {%- if block.settings.external_video_url.type == 'youtube' -%}
              <iframe
                data-external-video
                data-src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=1&rel=0&modestbranding=1"
                title="{{ block.settings.video_popup_title | default: block.settings.alt | default: 'Customer video' | escape }}"
                allow="autoplay; encrypted-media"
                allowfullscreen="allowfullscreen"
              ></iframe>
            {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
              <iframe
                data-external-video
                data-src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&title=0&byline=0&portrait=0"
                title="{{ block.settings.video_popup_title | default: block.settings.alt | default: 'Customer video' | escape }}"
                allow="autoplay; encrypted-media"
                allowfullscreen="allowfullscreen"
              ></iframe>
            {%- endif -%}
          {%- endif -%}
        </template>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  </div>
</div>
{%- endif -%}

{%- if has_popup_video -%}
  <script>
    (() => {
      const sectionRoot = document.getElementById('shopify-section-{{ section.id }}');

      if (!sectionRoot || sectionRoot.dataset.videoPopupReady === 'true') {
        return;
      }

      sectionRoot.dataset.videoPopupReady = 'true';

      const modal = sectionRoot.querySelector('[data-video-modal]');
      const openButtons = sectionRoot.querySelectorAll('[data-video-open]');
      const closeButtons = sectionRoot.querySelectorAll('[data-video-close]');
      const modalMedia = sectionRoot.querySelector('[data-video-modal-media]');
      if (!modal || !modalMedia || openButtons.length === 0) {
        return;
      }

      const openModal = (button) => {
        const templateId = button.getAttribute('data-video-template');
        const template = templateId ? sectionRoot.querySelector(`#${templateId}`) : null;

        if (!template) {
          return;
        }

        modalMedia.innerHTML = '';
        modalMedia.appendChild(template.content.cloneNode(true));

        modal.hidden = false;
        document.documentElement.classList.add('overflow-hidden');

        const externalVideo = modalMedia.querySelector('[data-external-video]');
        if (externalVideo && externalVideo.dataset.src) {
          externalVideo.setAttribute('src', externalVideo.dataset.src);
        }

        const localVideo = modalMedia.querySelector('video');
        if (localVideo) {
          localVideo.currentTime = 0;
          localVideo.play().catch(() => {});
        }
      };

      const closeModal = () => {
        modal.hidden = true;
        document.documentElement.classList.remove('overflow-hidden');
        modalMedia.innerHTML = '';
      };

      openButtons.forEach((button) => {
        button.addEventListener('click', () => openModal(button));
      });

      closeButtons.forEach((button) => {
        button.addEventListener('click', closeModal);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal.hidden) {
          closeModal();
        }
      });
    })();
  </script>
{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Origin video popup",
  "class": "shopify-section--origin-featured-video-popup",
  "tag": "section",
  "disabled_on": {
    "templates": [
      "password"
    ],
    "groups": [
      "header",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main image (Default/Denmark/Global)",
      "info": "Used when no video is set."
    },
    {
      "type": "image_picker",
      "id": "image_us_ca_mx",
      "label": "Main image (US, CA & MX)"
    },
    {
      "type": "video",
      "id": "main_video",
      "label": "Main video (Default/Denmark/Global)",
      "info": "When uploaded, plays automatically and loops in the right media area. Falls back to image if not set."
    },
    {
      "type": "video",
      "id": "video_us_ca_mx",
      "label": "Main video (US, CA & MX)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Featured Product"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Traditional household tasks are time-consuming and repetitive. At Scanovus, we rethink routines and design smarter alternatives that work for you.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Discover more"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "proof_text",
      "label": "Social proof text",
      "default": "Loved By 20,000+ Customers"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "content_background",
      "label": "Content panel background",
      "default": "#f4f2f0"
    },
    {
      "type": "select",
      "id": "market_visibility",
      "label": "Market visibility",
      "options": [
        {
          "value": "all",
          "label": "Global (All Markets)"
        },
        {
          "value": "denmark",
          "label": "Denmark Only"
        },
        {
          "value": "us_ca_mx",
          "label": "US, CA & MX Only"
        },
        {
          "value": "global_excluding_us_ca_mx",
          "label": "Global (Exclude US, CA & MX)"
        }
      ],
      "default": "all"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading"
    },
    {
      "type": "color_background",
      "id": "heading_gradient",
      "label": "Heading gradient"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card/block background"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card/block text"
    }
  ],
  "blocks": [
    {
      "type": "avatar",
      "name": "Customer avatar",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Avatar image"
        },
