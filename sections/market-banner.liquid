        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "background",
          "label": "Background"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text"
        },
        {
          "type": "color",
          "id": "button_background",
          "label": "Button background"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Country Specific Banner",
      "blocks": [
        {
          "type": "country_banner",
          "settings": {
            "is_default": true,
            "heading": "Global Store"
          }
        }
      ]
    }
  ]
}
{% endschema %}