    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading"
    },
    {
      "type": "color_background",
      "id": "heading_gradient",
      "label": "Heading gradient"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card/block background"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card/block text"
    }
  ],
  "blocks": [
    {
      "type": "country_banner",
      "name": "Country Banner",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_default",
          "label": "Set as Default Banner",
