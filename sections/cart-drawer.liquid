              </g>
              <g clip-path="url(#clip4_cart_drawer_trustpilot)">
                <path d="M13.3253 14.2771H0.951807C0.428313 14.2771 0 13.8488 0 13.3253V0.951807C0 0.428313 0.428313 0 0.951807 0H13.3253C13.8488 0 14.2771 0.428313 14.2771 0.951807V13.3253C14.2771 13.8488 13.8488 14.2771 13.3253 14.2771Z" fill="#579F78"/>
