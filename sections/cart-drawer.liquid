                <path d="M78.0482 14.2771H65.6747C65.1512 14.2771 64.7229 13.8488 64.7229 13.3253V0.951803C64.7229 0.428309 65.1512 -3.8147e-06 65.6747 -3.8147e-06H78.0482C78.5717 -3.8147e-06 79 0.428309 79 0.951803V13.3253C79 13.8488 78.5717 14.2771 78.0482 14.2771Z" fill="#579F78"/>
