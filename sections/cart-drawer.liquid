<style>

  #cart-drawer .cart-drawer__benefits,
  #cart-drawer .cart-drawer__trustpilot {
    display: flex;
  }

  #cart-drawer::part(body) {
    padding-left: 37px;
    padding-right: 37px;
    padding-bottom: 10px;
  }

  #cart-drawer::part(footer) {
    padding-top: 12px;
    padding-bottom: 0px;
  }

  #cart-drawer [slot="footer"] {
    gap: 15px !important;
    padding-left: 16px;
    padding-right: 16px;
  }

  #cart-drawer .cart-drawer__top .h5 {
    font-size: 32px;
    line-height: 1;
    font-weight: 500;
    font-family: var(--heading-font-family);
    color: {{ section.settings.custom_color_1 }};
  }

  #cart-drawer cart-count.count-bubble {
    min-width: 34px;
    height: 34px;
    border-radius: 999px;
    background: {{ section.settings.custom_background_2 }};
    color: {{ section.settings.custom_color_3 }};
    font-size: 16px;
    font-weight: 600;
    display: none;
  }

  #cart-drawer .cart-drawer__line-items line-item.line-item {
    background: {{ section.settings.custom_background_4 }};
    border-radius: 12px;
    padding: 19px 16px;
  }

  #cart-drawer .cart-drawer__line-items > * + * {
    padding-block-start: 12px;
    margin-top: 12px;
    border-top: 0;
  }

  #cart-drawer .cart-drawer__line-items .line-item__media-wrapper {
    width: 96px;
    min-width: 96px;
    grid-row: 1 / span 2;
  }

  #cart-drawer .cart-drawer__line-items .line-item {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    column-gap: 14px;
    row-gap: 10px;
    align-items: start;
  }

  #cart-drawer .cart-drawer__line-items .line-item__actions {
    grid-column: 2;
    margin-inline-start: 0;
  }

  #cart-drawer .cart-drawer__line-items .line-item__media {
    border-radius: 10px;
  }

  #cart-drawer .cart-drawer__line-items .line-item__info > .v-stack > a.bold,
  #cart-drawer .cart-drawer__line-items .line-item__info > .v-stack > p.bold {
    font-size: 16px;
    font-weight: 500;
    font-family: var(--heading-font-family);
    color: {{ section.settings.custom_color_5 }};
  }

  #cart-drawer .cart-drawer__line-items .line-item__info sale-price {
    font-size: 14px;
    font-weight: 500;
    font-family: var(--heading-font-family);
    color: {{ section.settings.custom_color_6 }};
  }

  #cart-drawer .cart-drawer__line-items .line-item__info compare-at-price {
    color: {{ section.settings.custom_color_7 }};
  }

  #cart-drawer .cart-drawer__line-items .line-item__info .badge {
    color: {{ section.settings.custom_color_8 }};
    background: {{ section.settings.custom_background_9 }};
    padding: 5px 10px;
    border-color: transparent;
  }

  #cart-drawer .cart-drawer__line-items .quantity-input {
    font-size: 14px;
    font-weight: 500;
    color: {{ section.settings.custom_color_10 }};
  }

  #cart-drawer .free-shipping-bar__status {
    background: {{ section.settings.custom_background_11 }};
    border-radius: 6px;
    padding: 8px 13px;
    font-size: 12px;
    color: {{ section.settings.custom_color_12 }};
    margin-bottom: 10px;
  }

  #cart-drawer .free-shipping-bar__helper {
    margin-top: 0px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    font-size: 14px;
    line-height: 1.3;
    color: {{ section.settings.custom_color_13 }};
  }

  #cart-drawer .free-shipping-bar__helper-text {
    flex: 1;
    font-weight: 400;
  }

  #cart-drawer .free-shipping-bar__helper-amount {
    white-space: nowrap;
    color: {{ section.settings.custom_color_14 }};
    font-size: 14px;
    font-weight: 500;
  }

  #cart-drawer .cart-drawer__recommendations {
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    padding-top: 18px;
    margin-top: 4px;
  }

  #cart-drawer .cart-drawer__recommendations-title {
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
    color: {{ section.settings.custom_color_15 }};
  }

  #cart-drawer .horizontal-product {
    border-radius: 0px;
    background: transparent;
    padding: 0px;
  }

  #cart-drawer .horizontal-product .horizontal-product__info .v-stack > a.text-sm.bold,
  #cart-drawer .horizontal-product .horizontal-product__info .v-stack > span.text-sm.bold {
    font-size: 12px;
    color: {{ section.settings.custom_color_16 }};
    font-weight: 400;
  }

  #cart-drawer .horizontal-product .horizontal-product__info sale-price {
    font-size: 12px;
    font-weight: 500;
  }

  #cart-drawer .horizontal-product .horizontal-product__info compare-at-price {
    color: {{ section.settings.custom_color_17 }};
  }

#cart-drawer .horizontal-product .horizontal-product__image {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
}
  #cart-drawer .cart-drawer__recommendations-scroll {
    max-height: 330px;
    overflow-y: auto;
    padding-right: 6px;
  }

  #cart-drawer .cart-drawer__recommendations-scroll::-webkit-scrollbar {
    width: 4px;
  }

  #cart-drawer .cart-drawer__recommendations-scroll::-webkit-scrollbar-thumb {
    background: {{ section.settings.custom_background_18 }};
    border-radius: 999px;
  }

  #cart-drawer .cart-drawer__recommendations-list {
    gap: 10px;
  }

  #cart-drawer .horizontal-product .button {
    min-height: 32px;
    border-radius: 999px;
    padding: 9px 20px;
    background: {{ section.settings.custom_background_19 }};
    border-color: transparent;
    font-size: 13px;
    font-family: var(--heading-font-family);
    font-weight: 500;
    color: {{ section.settings.custom_color_20 }};
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  #cart-drawer .horizontal-product .button::before {
    content: "+";
    font-size: 18px;
    line-height: 1;
    font-weight: 400;
    display: none;
  }

  #cart-drawer .cart-drawer__benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    {% comment %} padding-top: 12px; {% endcomment %}
    {% comment %} border-top: 1px solid rgba(0, 0, 0, 0.09); {% endcomment %}
    {% comment %} margin-top: 10px; {% endcomment %}
  }

  #cart-drawer .cart-drawer__benefit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12px;
    line-height: 1.2;
    color: {{ section.settings.custom_color_21 }};
    text-align: center;
  }

  #cart-drawer .cart-drawer__trustpilot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding-top: 10px;
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    margin-top: 10px;
  }

  #cart-drawer .cart-drawer__trustpilot-stars {
    display: inline-flex;
    gap: 2px;
  }

  #cart-drawer .cart-drawer__trustpilot-logo svg,
  #cart-drawer .cart-drawer__trustpilot-stars svg {
    display: block;
  }

  #cart-drawer .cart-drawer__trustpilot-logo {
    margin-right: 16px;
  }

  #cart-drawer [slot="footer"] .buy-buttons button[type="submit"] {
    border-radius: 999px;
    min-height: 62px;
    font-size: 16px;
    font-weight: 500;
    background: {{ section.settings.custom_background_22 }};
    width: 100%;
  }
  .cart-total {
    margin-top: 11px;
  }
  #cart-drawer [slot="footer"] .buy-buttons button[type="submit"] svg {
    display: none;
  }

  #cart-drawer [slot="footer"] .buy-buttons {
    flex-direction: column;
    width: calc(100% + 72px);
    margin-left: -36px;
    margin-right: -36px;
    background: {{ section.settings.custom_background_23 }};
    border-top: 1px solid rgba(206, 206, 206, 1);
    padding-right: 36px;
    padding-left: 36px;
    padding-top: 10px;
    padding-bottom: 30px;
  }
  @media (max-width: 699px) {
    #cart-drawer [slot="footer"] .buy-buttons {
      flex-direction: column;
      width: calc(100% + 40px);
      margin-left: -20px;
      margin-right: -20px;      
      padding-right: 20px;
      padding-left: 20px;
    }
  }
  #cart-drawer .cart-drawer__payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  #cart-drawer .cart-drawer__payment-icons svg {
    height: 20px;
    width: auto;
  }

  @media screen and (max-width: 999px) {
    #cart-drawer .cart-drawer__line-items line-item.line-item {
      padding: 16px 16px;
      gap: 16px;
    }

    #cart-drawer .cart-drawer__line-items > * + * {
      padding-block-start: 16px;
      margin-top: 16px;
    }

    #cart-drawer .cart-drawer__line-items .line-item__info > .v-stack > a.bold {
      font-size: 14px;
    }

    #cart-drawer .cart-drawer__line-items .line-item__info sale-price,
    #cart-drawer .cart-drawer__line-items .line-item__info compare-at-price {
      font-size: 12px;
    }

    #cart-drawer .cart-drawer__top .h5 {
      font-size: 24px;
    }

    #cart-drawer .free-shipping-bar__helper,
    #cart-drawer .free-shipping-bar__helper-amount {
      font-size: 12px;
    }

    #cart-drawer::part(body) {
      padding-left: 20px !important;
      padding-right: 20px !important;
    }

    #cart-drawer {
      top: 0 !important;
      height: 100dvh !important;
      padding-top: calc(var(--sticky-area-height, 0px) + 8px) !important;
    }

    #cart-drawer::part(content) {
      height: auto !important;
      max-height: calc(100dvh - var(--sticky-area-height, 0px) - 8px) !important;
      border-top-left-radius: 12px;
      border-top-right-radius: 12px;
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
    }

    #cart-drawer [slot="footer"] .buy-buttons > a {
      display: none;
    }
  }

</style>

<cart-drawer {% if request.design_mode %}handle-section-events{% endif %} class="cart-drawer drawer drawer--lg" id="cart-drawer">
  {%- if cart.item_count == 0 -%}
    <button is="close-button" aria-label="{{ 'general.accessibility.close' | t | escape }}">
      {%- render 'icon' with 'close' -%}
    </button>

    <div class="empty-state align-self-center">
      <div class="empty-state__icon-wrapper">
        {%- render 'icon' with 'cart', width: 32, height: 32, stroke_width: 1 -%}
        <span class="count-bubble count-bubble--lg">0</span>
      </div>

      <div class="prose">
        <p class="h5">{{ 'cart.general.empty' | t }}</p>

        {%- assign button_content = 'cart.general.continue_shopping' | t -%}
        {%- render 'button', href: settings.cart_empty_button_link, size: 'xl', content: button_content -%}
      </div>
    </div>
  {%- else -%}
    <div class="cart-drawer__inner">
      <div class="cart-drawer__top">
        <div class="h-stack items-center justify-between">
          <div class="h-stack grow gap-2 sm:gap-2.5">
            <p class="h5">{{- 'cart.general.title' | t -}}</p>
            <cart-count class="count-bubble count-bubble--md">{{ cart.item_count }}</cart-count>
          </div>

          <button type="button" is="close-button" class="drawer__close-icon">
            <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
            {%- render 'icon' with 'close' -%}
          </button>
        </div>

        {%- if settings.cart_show_free_shipping_threshold -%}
          {%- render 'free-shipping-bar' -%}
        {%- endif -%}
      </div>

      <div class="v-stack gap-6 sm:gap-8 cart-drawer__line-items-wrapper">
        <div class="cart-drawer__line-items">
          {%- for line_item in cart.items -%}
            {%- render 'line-item', line_item: line_item, show_desktop_quantity: true -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.show_recommendations -%}
          <div class="cart-drawer__recommendations">
            {%- liquid
              assign recommendation_source = section.settings.products
              assign rendered_recommendations = 0
            -%}

            {%- if recommendation_source.count > 0 -%}
              <div class="v-stack gap-2.5 sm:gap-4">
                {%- capture recommendations_markup -%}
                  {%- for recommended_product in recommendation_source limit: 8 -%}
                    {%- assign item_count_in_cart = cart | line_items_for: recommended_product -%}

                    {%- if item_count_in_cart.size == 0 -%}
                      {%- render 'horizontal-product', product: recommended_product, show_add_to_cart: true, background: section.settings.product_card_background, text_color: section.settings.product_card_text_color -%}
                      {%- assign rendered_recommendations = rendered_recommendations | plus: 1 -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endcapture -%}

                {%- if rendered_recommendations > 0 -%}
                  {%- if section.settings.recommendations_title != blank -%}
                    <p class="cart-drawer__recommendations-title">{{ section.settings.recommendations_title | escape }}</p>
                  {%- endif -%}

                  <div class="cart-drawer__recommendations-scroll">
                    <div class="horizontal-product-list cart-drawer__recommendations-list separate">
                      {{- recommendations_markup -}}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- elsif cart.item_count > 0 -%}
            {%- comment -%}Dynamic recommendations from Search & Discovery app{%- endcomment -%}
              <div id="cart-drawer-dynamic-recommendations" class="v-stack gap-2.5 sm:gap-4" style="display:none;"
                   data-product-id="{{ cart.items.first.product_id | json }}"
                   data-cart-item-ids="{{ cart.items | map: 'product_id' | json | escape }}">
                {%- if section.settings.recommendations_title != blank -%}
                  <p class="cart-drawer__recommendations-title">{{ section.settings.recommendations_title | escape }}</p>
                {%- endif -%}
                <div class="cart-drawer__recommendations-scroll">
                  <div class="horizontal-product-list cart-drawer__recommendations-list separate" id="cart-drawer-dynamic-recs-list"></div>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>

    <div class="v-stack gap-4 sm:gap-6" slot="footer">
      {%- if section.settings.allow_discount_application or cart.cart_level_discount_applications.size > 0 -%}
        <div class="v-stack gap-2.5">
          {%- if section.settings.allow_discount_application -%}
            {%- render 'cart-discount', section: section -%}
          {%- endif -%}

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <div class="h-stack gap-2">
              {%- for discount_application in cart.cart_level_discount_applications -%}
                <div class="h-stack gap-4 justify-between">
                  <div class="badge">
                    {%- render 'icon' with 'discount' -%} {{ discount_application.title }} (-{{ discount_application.total_allocated_amount | money }})

                    {%- if section.settings.allow_discount_application and discount_application.type != '' -%}
                      <cart-discount-remove-button discount-code="{{ discount_application.title | escape }}" class="h-stack align-center">
                        <button type="button">{%- render 'icon' with 'delete', width: 8, stroke_width: 3 -%}</button>
                      </cart-discount-remove-button>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="v-stack gap-1">
        <div class="cart-drawer__benefits">
          <div class="cart-drawer__benefit">
          <svg width="21" height="14" viewBox="0 0 21 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
