              </defs>
            </svg>
          </span>
          <span>{{ section.settings.trustpilot_rating_text | escape }}</span>
        </div>
        

        {% comment %} {%- if section.settings.show_shipping_text -%}
          {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
            <p class="text-subdued text-sm">{{ 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}</p>
          {%- elsif cart.taxes_included -%}
            <p class="text-subdued text-sm">{{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}</p>
          {%- elsif shop.shipping_policy.body != blank -%}
            <p class="text-subdued text-sm">{{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}</p>
          {%- else -%}
            <p class="text-subdued text-sm">{{ 'cart.general.taxes_and_shipping_at_checkout' | t }}</p>
          {%- endif -%}
        {%- endif -%} {% endcomment %}

        {%- if section.settings.show_cart_note -%}
          <button type="button" class="justify-self-start" aria-controls="cart-drawer-note">
            <span class="link text-sm text-subdued">
              {%- if cart.note == blank -%}
                {{- 'cart.general.add_order_note' | t -}}
              {%- else -%}
                {{- 'cart.general.edit_order_note' | t -}}
              {%- endif -%}
            </span>
          </button>

          <cart-note-dialog id="cart-drawer-note" class="cart-drawer__note">
            <div class="cart-drawer__note-inner">
              <div class="v-stack gap-4 sm:gap-6">
                <p class="h5">{{ 'cart.general.order_note' | t }}</p>

                <cart-note class="v-stack gap-4">
                  {%- assign order_note = 'cart.general.order_note' | t -%}
                  {%- assign order_save_label = 'cart.general.save_note' | t -%}

                  {%- render 'input', name: 'note', multiline: 3, label: order_note, value: cart.note -%}

                  <div class="justify-self-start">
                    {%- render 'button', type: 'button', content: order_save_label, size: 'lg', is: 'close-button', secondary: true -%}
                  </div>
                </cart-note>
              </div>
            </div>
          </cart-note-dialog>
        {%- endif -%}
      </div>

      <form action="{{ routes.cart_url }}" method="POST" class="buy-buttons {% if section.settings.show_checkout_button %}buy-buttons--compact{% endif %}" style="display: block;">
        {%- assign checkout_label = 'cart.general.checkout' | t -%}
        <div class="h-stack gap-4 justify-between cart-total" style="margin-bottom: 16px;">
          <span class="h5">{{ 'cart.general.total' | t }}</span>
          <span class="h5">{{- cart.total_price | money_with_currency -}}</span>
        </div>
        {%- if section.settings.discount_code_hint_text != blank -%}
          <p class="text-subdued text-sm cart-discount-text" style="display: none;">{{ section.settings.discount_code_hint_text }}</p>
        {%- endif -%}

        {%- if section.settings.show_terms_checkbox -%}
          {%- capture terms_label -%}{{ 'cart.general.terms_label' | t }}{%- endcapture -%}
          {%- if terms_label contains 'translation missing' or terms_label contains 'Translation missing' -%}
            {%- assign terms_label = section.settings.terms_label -%}
          {%- endif -%}

          {%- capture terms_link_text -%}{{ 'cart.general.terms_link_text' | t }}{%- endcapture -%}
          {%- if terms_link_text contains 'translation missing' or terms_link_text contains 'Translation missing' -%}
            {%- assign terms_link_text = section.settings.terms_link_text -%}
          {%- endif -%}

          {%- capture terms_warning_text -%}{{ 'cart.general.terms_warning_text' | t }}{%- endcapture -%}
          {%- if terms_warning_text contains 'translation missing' or terms_warning_text contains 'Translation missing' -%}
            {%- assign terms_warning_text = section.settings.terms_warning_text -%}
          {%- endif -%}

          <div class="checkbox-container cart-drawer__terms" style="margin-bottom: 16px;">
            <input type="checkbox" id="cart-terms-checkbox" class="checkbox" checked required>
            <label for="cart-terms-checkbox" class="text-sm" style="cursor: pointer;">
              {{ terms_label }} <a href="{{ section.settings.terms_link_url }}" style="text-decoration: underline;">{{ terms_link_text }}</a>
            </label>
          </div>
          <p id="cart-terms-warning" style="display: none; color: {{ section.settings.terms_warning_color | default: '#c0392b' }}; font-size: 13px; text-align: center; margin: -8px 0 12px; animation: termsShake 0.4s ease;">{{ terms_warning_text }}</p>
          <style>

            @keyframes termsShake {
              0%, 100% { transform: translateX(0); }
              20% { transform: translateX(-6px); }
              40% { transform: translateX(6px); }
              60% { transform: translateX(-4px); }
              80% { transform: translateX(4px); }
            }
          
</style>
        {%- endif -%}

        {%- if section.settings.show_checkout_button -%}
          {%- render 'button', type: 'submit', content: checkout_label, icon: 'picto-lock', name: 'checkout', size: 'xl' -%}
        {%- endif -%}
        {%- if shop.enabled_payment_types.size > 0 -%}
          <ul class="cart-drawer__payment-icons" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="contents">{{ type | payment_type_svg_tag }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </form>

      

      
    </div>
  {%- endif -%}
</cart-drawer>

