<script>
  document.addEventListener('DOMContentLoaded', function() {
    var warningTimeout = null;
    var loadedProductId = null;
    var loadedCartItemIds = '';

    function updateCheckoutButton() {
      var checkbox = document.getElementById('cart-terms-checkbox');
      var checkoutBtn = document.querySelector('#cart-drawer button[name="checkout"]');
      var warning = document.getElementById('cart-terms-warning');
      if (checkbox && checkoutBtn) {
        if (!checkbox.checked) {
          checkoutBtn.setAttribute('disabled', 'disabled');
          checkoutBtn.style.opacity = '0.5';
          checkoutBtn.style.cursor = 'not-allowed';
        } else {
          checkoutBtn.removeAttribute('disabled');
          checkoutBtn.style.opacity = '1';
          checkoutBtn.style.cursor = 'pointer';
          if (warning) warning.style.display = 'none';
        }
      }
    }

    function showWarning() {
      var warning = document.getElementById('cart-terms-warning');
      var checkbox = document.getElementById('cart-terms-checkbox');
      if (!warning || !checkbox || checkbox.checked) return;
      warning.style.display = 'block';
      warning.style.animation = 'none';
      void warning.offsetWidth;
      warning.style.animation = 'termsShake 0.4s ease';
      if (warningTimeout) clearTimeout(warningTimeout);
      warningTimeout = setTimeout(function() { warning.style.display = 'none'; }, 3000);
    }

    function updateRecommendations() {
      var container = document.getElementById('cart-drawer-dynamic-recommendations');
      var list = document.getElementById('cart-drawer-dynamic-recs-list');
      if (!container || !list) return;

      var productId = container.getAttribute('data-product-id');
      var cartItemIdsStr = container.getAttribute('data-cart-item-ids') || '[]';
      if (!productId) {
        container.style.display = 'none';
        return;
      }

      // Avoid duplicate loading for same product + cart state, only if already populated
      if (loadedProductId === productId && loadedCartItemIds === cartItemIdsStr && list.children.length > 0) {
        return;
      }

      loadedProductId = productId;
      loadedCartItemIds = cartItemIdsStr;

      var cartItemIds = JSON.parse(cartItemIdsStr);
      var limit = 8;

      console.log('Cart Recommendations: Fetching complementary products for ID:', productId);
      fetch(Shopify.routes.root + 'recommendations/products.json?product_id=' + productId + '&limit=' + limit + '&intent=complementary')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          console.log('Cart Recommendations: Complementary results:', data.products ? data.products.length : 0);
          if (!data.products || data.products.length === 0) {
            console.log('Cart Recommendations: Falling back to related products');
            return fetch(Shopify.routes.root + 'recommendations/products.json?product_id=' + productId + '&limit=' + limit + '&intent=related')
              .then(function(r) { return r.json(); });
          }
          return data;
        })
        .then(function(data) {
          console.log('Cart Recommendations: Final data products:', data.products ? data.products.length : 0);
          if (!data.products || data.products.length === 0) {
            container.style.display = 'none';
            return;
          }

          var filtered = data.products.filter(function(p) {
            return cartItemIds.indexOf(p.id) === -1;
          });
          if (filtered.length === 0) {
            container.style.display = 'none';
            return;
          }

          var html = '';
          filtered.slice(0, 6).forEach(function(product) {
            var variant = product.variants[0];
            var price = variant ? (variant.price / 100).toFixed(2) : '0.00';
            var comparePrice = variant && variant.compare_at_price ? (variant.compare_at_price / 100).toFixed(2) : null;
            var image = product.featured_image || (product.images && product.images[0]) || '';
            var imageUrl = typeof image === 'string' ? image : (image.src || '');
            if (imageUrl) imageUrl = imageUrl.replace(/(\.[^.]+)$/, '_200x200$1');
            var currencyFormatter = new Intl.NumberFormat(Shopify.locale, { style: 'currency', currency: Shopify.currency.active });
            var priceNum = variant ? variant.price / 100 : 0;
            var formattedPrice = currencyFormatter.format(priceNum);

            html += '<div class="horizontal-product">';
            html += '  <a href="' + product.url + '">';
            html += '    <img class="horizontal-product__image" src="' + imageUrl + '" alt="' + (product.title || '').replace(/"/g, '&quot;') + '" width="80" height="80" loading="lazy">';
            html += '  </a>';
            html += '  <div class="horizontal-product__info">';
            html += '    <div class="v-stack gap-0.5">';
            html += '      <a href="' + product.url + '" class="text-sm bold">' + product.title + '</a>';
            html += '      <sale-price class="text-sm">';
            html += '        <span class="fw-semibold">' + formattedPrice + '</span>';
            html += '      </sale-price>';
            html += '    </div>';
            if (variant) {
              html += '    <form method="post" action="' + Shopify.routes.root + 'cart/add" is="product-form" id="complementary-product-' + variant.id + '">';
              html += '      <input type="hidden" name="id" value="' + variant.id + '">';
              html += '      <input type="hidden" name="quantity" value="1">';
              html += '      <button type="submit" is="custom-button" class="button button--sm">' + {{ 'product.general.add_to_cart_short' | t | json }} + '</button>';
              html += '    </form>';
            }
            html += '  </div>';
            html += '</div>';
          });

          list.innerHTML = html;
          container.style.display = '';
        })
        .catch(function(err) {
          console.warn('Cart recommendations error:', err);
          container.style.display = 'none';
        });
    }

    updateCheckoutButton();
    updateRecommendations();

    document.body.addEventListener('change', function(e) {
      if (e.target.id === 'cart-terms-checkbox') {
        updateCheckoutButton();
      }
    });

    document.body.addEventListener('click', function(e) {
      var btn = e.target.closest('#cart-drawer button[name="checkout"]');
      if (btn && btn.hasAttribute('disabled')) {
        e.preventDefault();
        e.stopPropagation();
        showWarning();
      }
    }, true);

    var cartDrawer = document.getElementById('cart-drawer');
    if (cartDrawer) {
      var observer = new MutationObserver(function() {
        updateCheckoutButton();
        updateRecommendations();
      });
      observer.observe(cartDrawer, { childList: true, subtree: true });
    }
  });
</script>
