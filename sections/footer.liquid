{%- assign newsletter_block = section.blocks | where: 'type', 'newsletter' | first -%}



{%- if section.blocks.size > 3 -%}

{%- render 'section-color-css' -%}
<style>
  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      {%- if newsletter_block != blank -%}
        --footer-block-list-gap: var(--spacing-10);
      {%- endif -%}

      --footer-block-list-justify-content: space-between;
    }
  }
</style>
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    --container-gutter: 80px;
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} {
      --container-gutter: 10px;
    }
  }

  #shopify-section-{{ section.id }} .footer__aside-bottom {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: 14px;
    align-items: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .footer__payment-icons {
    gap: 6px;
    justify-self: center;
    order: 0;
    grid-area: payments;
  }

  #shopify-section-{{ section.id }} .footer__payment-icons svg {
    width: 28px;
  }

  #shopify-section-{{ section.id }} .footer__trustpilot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    text-align: center;
    justify-self: center;
    grid-area: trustpilot;
  }

  #shopify-section-{{ section.id }} .footer__trustpilot svg {
    display: block;
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .footer__trustpilot span {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .footer__copyright {
    justify-self: center;
    text-align: center;
    order: 0;
    grid-area: copyright;
  }

  #shopify-section-{{ section.id }} .footer__menu-toggle {
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    color: inherit;
    font: inherit;
    width: 100%;
    text-align: center;
    cursor: pointer;
    font-family: var(--text-font-family);
  }

  #shopify-section-{{ section.id }} .footer__menu-links {
    margin-top: 10px;
    justify-items: center;
    overflow: hidden;
    opacity: 1;
    max-height: none;
    transition: max-height 0.28s ease, opacity 0.2s ease, margin-top 0.2s ease;
  }

  #shopify-section-{{ section.id }} .footer__social-mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .footer__social-desktop {
    display: block;
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .footer__block-list {
      display: block;
      grid-template-columns: minmax(0, 1fr);
      justify-items: stretch;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .footer__block {
      width: 100%;
      justify-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .footer__block--menu {
      max-width: none;
      width: 100%;
      padding-bottom: 16px;
      padding-top: 16px;  
    }
    #shopify-section-{{ section.id }} .footer__block--menu:not(:last-child) {
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
     
    }
    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-toggle::after {
      content: "";
      margin-inline-start: 8px;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-toggle[aria-expanded="false"]::after {
      content: "+";
      display: none;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-toggle[aria-expanded="true"]::after {
      content: "−";
      display: none;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-links[hidden] {
      display: none;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-links {
      max-height: 0;
      opacity: 0;
      margin-top: 0;
    }

    #shopify-section-{{ section.id }} .footer__block--menu.is-open .footer__menu-links {
      opacity: 1;
      margin-top: 10px;
    }

    #shopify-section-{{ section.id }} .footer__payment-icons,
    #shopify-section-{{ section.id }} .footer__trustpilot,
    #shopify-section-{{ section.id }} .footer__copyright {
      grid-area: auto;
      justify-self: center;
    }

    #shopify-section-{{ section.id }} .footer__copyright {
      order: 2;
    }

    #shopify-section-{{ section.id }} .footer__trustpilot {
      order: 1;
      flex-direction: column;
      gap: 9px;
      margin-bottom: 35px;
    }

    #shopify-section-{{ section.id }} .footer__payment-icons {
      order: 3;
    }

    #shopify-section-{{ section.id }} .footer__social-desktop {
      display: none !important;
    }

    #shopify-section-{{ section.id }} .footer__social-mobile {
      display: flex;
      justify-content: center;
      width: 100%;
      margin-top: 16px;
      margin-bottom: 2px;
    }

    #shopify-section-{{ section.id }} .footer__social-mobile .social-media {
      justify-content: center;
      width: 100%;
      margin-top: 0;
    }

    #shopify-section-{{ section.id }} .footer__social-mobile .social-media .tap-area {
      width: 32px;
      height: 32px;
      display: grid;
      place-items: center;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .footer__social-mobile .social-media svg {
      width: 32px;
      height: 32px;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .footer__social-mobile {
      display: none !important;
    }

    #shopify-section-{{ section.id }} .footer__social-desktop {
      display: block;
    }

    #shopify-section-{{ section.id }} .footer__block--menu {
      text-align: left;
      justify-items: start;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-toggle {
      text-align: left;
    }

    #shopify-section-{{ section.id }} .footer__block--menu .footer__menu-links {
      justify-items: start;
    }

    #shopify-section-{{ section.id }} .footer__aside-bottom {
      grid-template-columns: auto minmax(0, 1fr) auto;
      grid-template-areas: "copyright trustpilot payments";
      column-gap: 20px;
      row-gap: 0;
    }

    #shopify-section-{{ section.id }} .footer__payment-icons {
      justify-self: end;
    }

    #shopify-section-{{ section.id }} .footer__trustpilot {
      justify-self: center;
    }

    #shopify-section-{{ section.id }} .footer__copyright {
      justify-self: start;
      text-align: left;
    }
  }
</style>

<div class="footer">
  <div class="container">
    <div class="footer__wrapper">
      {%- comment -%}
      ------------------------------------------------------------------------------------------------------------------
      BLOCK AREA
      ------------------------------------------------------------------------------------------------------------------
      {%- endcomment -%}

      {%- if section.blocks.size > 0 -%}
        <div class="footer__block-list empty:hidden">
          {%- assign desktop_social_rendered = false -%}
          {%- for block in section.blocks -%}
            {%- render 'block-color-css', block: block -%}
            {%- capture is_block_visible -%}{%- render 'block-market-check', block: block -%}{%- endcapture -%}
            {%- if is_block_visible contains 'false' -%}{%- continue -%}{%- endif -%}

            {%- case block.type -%}
              {%- when '@app' -%}
                <div class="footer__block footer__block--app">
                  {%- render block -%}
                </div>

              {%- when 'text' -%}
                {%- assign text_block_social_media = blank -%}
                {%- if desktop_social_rendered == false and block.settings.show_social_icons -%}
                  {%- capture text_block_social_media -%}
                    <div class="footer__social-desktop">
                      {%- render 'social-media', size: 'sm' -%}
                    </div>
                  {%- endcapture -%}
                  {%- assign desktop_social_rendered = true -%}
                {%- endif -%}

                {%- if block.settings.title != blank or block.settings.content != blank or block.settings.show_site_logo and block.settings.logo_image != blank or block.settings.show_site_logo and shop.brand.logo != blank or shop.features.follow_on_shop? and block.settings.enable_follow_on_shop or text_block_social_media != blank -%}
                  <div class="footer__block footer__block--text" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                      <p class="bold">{{ block.settings.title | escape }}</p>
                    {%- endif -%}

                    {%- if block.settings.show_site_logo and block.settings.logo_image != blank -%}
                      {%- capture sizes -%}{{ block.settings.logo_width }}px{%- endcapture -%}
                      {%- capture widths -%}{{ block.settings.logo_width }}, {{ block.settings.logo_width | times: 2 | at_most: block.settings.logo_image.width }}{%- endcapture -%}
                      {%- capture style -%}max-width: {{ block.settings.logo_width }}px{%- endcapture -%}
                      {{- block.settings.logo_image | image_url: width: block.settings.logo_image.width | image_tag: loading: 'lazy', style: style, sizes: sizes, widths: widths, alt: shop.name -}}
                    {%- elsif block.settings.show_site_logo and shop.brand.logo != blank -%}
                      {%- capture sizes -%}{{ block.settings.logo_width }}px{%- endcapture -%}
                      {%- capture widths -%}{{ block.settings.logo_width }}, {{ block.settings.logo_width | times: 2 | at_most: shop.brand.logo.width }}{%- endcapture -%}
                      {%- capture style -%}max-width: {{ block.settings.logo_width }}px{%- endcapture -%}
                      {{- shop.brand.logo | image_url: width: shop.brand.logo.width | image_tag: loading: 'lazy', style: style, sizes: sizes, widths: widths, alt: shop.name -}}
                    {%- endif -%}

                    {%- if block.settings.content != blank -%}
                      <div class="prose text-subdued">
                        {{- block.settings.content -}}
                      </div>
                    {%- endif -%}

                    {%- if text_block_social_media != blank -%}
                      {{- text_block_social_media -}}
                    {%- endif -%}

                    {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                      <div class="follow-on-shop">
                        {{- shop | login_button: action: 'follow' -}}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              {%- when 'links' -%}
                {%- if block.settings.menu != blank -%}
                  <div class="footer__block footer__block--menu" {{ block.shopify_attributes }}>
                    {%- if block.settings.show_menu_title -%}
                      {%- assign menu_title = block.settings.menu_title | default: block.settings.menu.title -%}
                      <button
                        type="button"
                        class="footer__menu-toggle bold"
                        aria-expanded="false"
                        aria-controls="footer-menu-{{ section.id }}-{{ block.id }}"
                      >
                        {{ menu_title }}
                      </button>
                    {%- endif -%}

                    <ul id="footer-menu-{{ section.id }}-{{ block.id }}" class="footer__menu-links v-stack gap-3" role="list">
                      {%- for link in block.settings.menu.links -%}
                        <li>
                          <a href="{{ link.url }}" class="inline-block link-faded break-all">{{ link.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}

              {%- when 'newsletter' -%}
                <div class="footer__block footer__block--newsletter" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {%- capture sizes -%}{{ block.settings.image_width }}px{%- endcapture -%}
                    {%- capture widths -%}{{ block.settings.image_width }}, {{ block.settings.image_width | times: 2 | at_most: block.settings.image.width }}{%- endcapture -%}
                    {%- capture style -%}max-width: {{ block.settings.image_width }}px{%- endcapture -%}
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: 'lazy', style: style, sizes: sizes, widths: widths -}}
                  {%- endif -%}

                  <div class="v-stack gap-6">
                    {%- if block.settings.title != blank -%}
                      <p class="{{ block.settings.heading_size }}">{{- block.settings.title | escape -}}</p>
                    {%- endif -%}

                    {%- if block.settings.content != blank -%}
                      <div class="prose text-subdued">
                        {{- block.settings.content -}}
                      </div>
                    {%- endif -%}

                    {%- form 'customer', id: 'footer-newsletter', class: 'footer__newsletter-form form' -%}
                      {%- if form.posted_successfully? -%}
                        {%- capture success_message -%}{{ 'general.newsletter.subscribed_successfully' | t }}{%- endcapture -%}
                        {%- render 'banner', content: success_message, status: 'success' -%}
                      {%- else -%}
                        {%- if form.errors -%}
                          {%- capture error_message -%}{{ form.errors.translated_fields['email'] }} {{ form.errors.messages['email'] }}{%- endcapture -%}
                          {%- render 'banner', content: error_message, status: 'error' -%}
                        {%- endif -%}

                        <input type="hidden" name="contact[tags]" value="newsletter">

                        {%- capture label -%}{{ 'general.newsletter.email' | t }}{%- endcapture -%}
                        {%- render 'input', name: 'contact[email]', label: label, type: 'email', required: true, autocomplete: 'email', enterkeyhint: 'send', self_submit: true -%}
                      {%- endif -%}
                    {%- endform -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- if desktop_social_rendered -%}
          <div class="footer__social-mobile">
            {%- render 'social-media', size: 'sm' -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%}
      ------------------------------------------------------------------------------------------------------------------
      SECONDARY AREA
      ------------------------------------------------------------------------------------------------------------------
      {%- endcomment -%}

      <div class="footer__aside empty:hidden">
        {%- comment -%}
        ----------------------------------------------------------------------------------------------------------------
        SOCIAL MEDIA + LOCALIZATION
        ----------------------------------------------------------------------------------------------------------------
        {%- endcomment -%}

        {%- if section.settings.show_social_media -%}
          {%- capture social_media -%}{%- render 'social-media' -%}{%- endcapture -%}
        {%- endif -%}

        {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
          {%- assign country_selector = true -%}
        {%- endif -%}

        {%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
          {%- assign locale_selector = true -%}
        {%- endif -%}

        {%- if social_media != blank or country_selector or locale_selector -%}
          {% comment %} <div class="footer__aside-top">
            {{- social_media -}}

            {%- if country_selector or locale_selector -%}
              <div class="h-stack gap-6">
                {%- if social_media == blank -%}
                  {%- assign popover_horizontal_position = 'start' -%}
                {%- else -%}
                  {%- assign popover_horizontal_position = 'end' -%}
                {%- endif -%}

                {%- if country_selector -%}
                  {%- render 'localization-selector', type: 'country', show_country_name: section.settings.show_country_name, show_country_flag: section.settings.show_country_flag, popover_horizontal_position: popover_horizontal_position -%}
                {%- endif -%}

                {%- if locale_selector -%}
                  {%- render 'localization-selector', type: 'locale', popover_horizontal_position: popover_horizontal_position -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div> {% endcomment %}
        {%- endif -%}

        {%- comment -%}
        ----------------------------------------------------------------------------------------------------------------
        COPYRIGHT + PAYMENT METHODS
        ----------------------------------------------------------------------------------------------------------------
        {%- endcomment -%}

        <div class="footer__aside-bottom">
          {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
            <ul class="footer__payment-icons h-stack wrap gap-2">
              {%- for type in shop.enabled_payment_types -%}
                <li class="contents">{{ type | payment_type_svg_tag }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          <div class="footer__trustpilot">
            <svg width="79" height="15" viewBox="0 0 79 15" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <g clip-path="url(#clip0_8_204_summary_template--28161873805639__origin_review_slider_HynL6G)">
