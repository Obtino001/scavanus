<script>
  (() => {
    const sectionRoot = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionRoot || sectionRoot.dataset.footerMenusReady === 'true') {
      return;
    }

    sectionRoot.dataset.footerMenusReady = 'true';

    const mobileQuery = window.matchMedia('(max-width: 999px)');
    const menuBlocks = Array.from(sectionRoot.querySelectorAll('.footer__block--menu'));

    if (!menuBlocks.length) {
      return;
    }

    const setMenuState = (menuBlock, isOpen, animate = true) => {
      const toggle = menuBlock.querySelector('.footer__menu-toggle');
      const linksList = menuBlock.querySelector('.footer__menu-links');

      if (!toggle || !linksList) {
        return;
      }

      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      menuBlock.classList.toggle('is-open', isOpen);

      if (!mobileQuery.matches) {
        linksList.style.maxHeight = '';
        linksList.style.opacity = '';
        linksList.style.marginTop = '';
        return;
      }

      if (isOpen) {
        linksList.style.maxHeight = `${linksList.scrollHeight}px`;
        linksList.style.opacity = '1';
        linksList.style.marginTop = '10px';
      } else {
        if (!animate) {
          linksList.style.maxHeight = '0px';
          linksList.style.opacity = '0';
          linksList.style.marginTop = '0px';
          return;
        }

        linksList.style.maxHeight = `${linksList.scrollHeight}px`;
        window.requestAnimationFrame(() => {
          linksList.style.maxHeight = '0px';
          linksList.style.opacity = '0';
          linksList.style.marginTop = '0px';
        });
      }
    };

    const syncMenusWithViewport = () => {
      const isMobile = mobileQuery.matches;

      menuBlocks.forEach((menuBlock) => {
        const toggle = menuBlock.querySelector('.footer__menu-toggle');
        const linksList = menuBlock.querySelector('.footer__menu-links');

        if (!toggle || !linksList) {
          return;
        }

        if (isMobile) {
          toggle.removeAttribute('disabled');
          setMenuState(menuBlock, false, false);
        } else {
          toggle.setAttribute('disabled', 'disabled');
          setMenuState(menuBlock, true, false);
        }
      });
    };

    menuBlocks.forEach((menuBlock) => {
      const toggle = menuBlock.querySelector('.footer__menu-toggle');

      if (!toggle) {
        return;
      }

      toggle.addEventListener('click', () => {
        if (!mobileQuery.matches) {
          return;
        }

        const shouldOpen = toggle.getAttribute('aria-expanded') !== 'true';
        setMenuState(menuBlock, shouldOpen);
      });
    });

    syncMenusWithViewport();

    if (typeof mobileQuery.addEventListener === 'function') {
      mobileQuery.addEventListener('change', syncMenusWithViewport);
    } else if (typeof mobileQuery.addListener === 'function') {
      mobileQuery.addListener(syncMenusWithViewport);
    }
  })();
</script>

