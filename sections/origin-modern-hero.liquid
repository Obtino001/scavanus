{% schema %}
{
  "name": "Origin modern hero",
  "class": "shopify-section--origin-modern-hero shopify-section--collection-list",
  "tag": "section",
  "disabled_on": {
    "templates": [
      "password"
    ],
    "groups": [
      "header",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "When uploaded, video plays automatically and loops on page load. Falls back to image if no video."
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video",
      "info": "Optional. Uses main video if not set."
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Image size",
      "options": [
        {
          "value": "auto",
          "label": "Original image ratio"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "fill",
          "label": "Fill screen"
        }
      ],
      "default": "md"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Effortless Solutions for Modern Living."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h1",
          "label": "Large"
        },
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h3",
          "label": "Small"
        }
      ],
      "default": "h1"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Innovative products designed to simplify your everyday routine without compromising on quality or aesthetics.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating row",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "Rated 4.7/5 on Trustpilot"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content width",
      "min": 380,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 760
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 25
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#1f2937"
    },
    {
      "type": "select",
      "id": "market_visibility",
      "label": "Market visibility",
      "options": [
        {
          "value": "all",
          "label": "Global (All Markets)"
        },
        {
          "value": "denmark",
          "label": "Denmark Only"
        },
        {
          "value": "us_ca_mx",
          "label": "US, CA & MX Only"
        },
        {
          "value": "global_excluding_us_ca_mx",
          "label": "Global (Exclude US, CA & MX)"
        }
      ],
      "default": "all"
    }
  ],
  "presets": [
    {
      "name": "Origin modern hero",
      "category": "Banners"
    }
  ]
}
{% endschema %}
