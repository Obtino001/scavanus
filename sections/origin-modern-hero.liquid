{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --content-over-media-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --section-spacing-block-start: 0px;
  }


  #shopify-section-{{ section.id }} .origin-modern-hero {
    overflow: hidden;
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero picture,
  #shopify-section-{{ section.id }} .origin-modern-hero img,
  #shopify-section-{{ section.id }} .origin-modern-hero video,
  #shopify-section-{{ section.id }} .origin-modern-hero video-media {
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero video-media video {
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__content {
    max-width: {{ section.settings.content_max_width }}px;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__content :is(h1, h2, h3, h4, h5, h6, .h0, .h1, .h2, .h3, .h4, .h5, .h6) {
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__heading {
    font-size: 40px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__description {
    max-width: 508px;
    font-size: 16px;
    line-height: 1.3;
    margin-top: 5px;
    font-weight: 400;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 16px 95px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    margin-top: 34px;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__rating {
    margin-top: 18px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    justify-content: center;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__rating-icon {
    width: 79px;
    height: 15px;
    display: block;
  }

  #shopify-section-{{ section.id }} .origin-modern-hero__rating-text {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .origin-modern-hero__heading {
      font-size: 32px;
    }
    #shopify-section-{{ section.id }} .origin-modern-hero__description {
      max-width: 249px;
    }
    #shopify-section-{{ section.id }} .origin-modern-hero__rating {
      flex-direction: column;
    }
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} .origin-modern-hero.content-over-media {
      min-height: 640px;
    }
    
  }
</style>

{%- capture is_section_visible -%}{%- render 'block-market-check', block: section -%}{%- endcapture -%}
{%- if is_section_visible contains 'true' -%}
<div {% render 'section-properties' %}>
  <div class="section-stack">
    <div class="container1">
      <a {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}>
      <div class="origin-modern-hero content-over-media content-over-media--{{ section.settings.image_size }} shadow-block rounded-lg" {% render 'surface', text_color: section.settings.text_color %}>
        {%- if section.settings.video != blank -%}          
            {%- capture video_sizes -%}(max-width: 699px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){%- endcapture -%}
            {%- assign poster_image = section.settings.image | default: section.settings.video.preview_image -%}
            {%- if section.settings.mobile_video != blank -%}
              {%- assign mobile_poster = section.settings.mobile_image | default: section.settings.mobile_video.preview_image | default: poster_image -%}
              <video-media autoplay class="sm:hidden" style="--aspect-ratio: {{ section.settings.mobile_video.aspect_ratio }}">
                {{ section.settings.mobile_video | video_tag: class: 'object-cover sm:hidden', controls: false, autoplay: true, playsinline: true, muted: true, loop: true, preload: 'auto', image_size: '1000x' }}
                {%- if mobile_poster != blank -%}{{ mobile_poster | image_url: width: mobile_poster.width | image_tag: sizes: '100vw', widths: '200,400,600,800,1000,1200,1400,1600' }}{%- endif -%}
              </video-media>
            {%- endif -%}
            <video-media autoplay {% if section.settings.mobile_video != blank %}class="hidden sm:block"{% endif %} style="--aspect-ratio: {{ section.settings.video.aspect_ratio }}">
              {{ section.settings.video | video_tag: playsinline: true, preload: 'auto', muted: true, loop: true, autoplay: true, controls: false, image_size: '2000x' }}
              {%- if poster_image != blank -%}{{ poster_image | image_url: width: poster_image.width | image_tag: sizes: video_sizes, widths: '400,600,800,1000,1200,1400,1600,1800,2000,2200,2400' }}{%- endif -%}
            </video-media>         
        {%- elsif section.settings.image != blank -%}
          {%- capture sizes -%}(max-width: 699px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){%- endcapture -%}
          {%- capture fetch_priority -%}{% if section.index == 1 %}high{% else %}low{% endif %}{%- endcapture -%}

          <picture>
            {%- if section.settings.mobile_image != blank -%}
              <source
                media="(max-width: 699px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w, {{ section.settings.mobile_image | image_url: width: 1200 }} 1200w"
                width="{{ section.settings.mobile_image.width }}"
                height="{{ section.settings.mobile_image.height }}"
              >
            {%- endif -%}

            {{- section.settings.image | image_url: width: section.settings.image.width | image_tag: sizes: sizes, fetchpriority: fetch_priority, widths: '400,600,800,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
          </picture>
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
        {%- endif -%}

        <div class="place-self-center text-center sm:place-self-center sm:text-center">
          <div class="prose origin-modern-hero__content">
            {%- if section.settings.heading != blank -%}
              <p class="{{ section.settings.heading_size }} origin-modern-hero__heading">{{ section.settings.heading | escape }}</p>
            {%- endif -%}

            {%- if section.settings.description != blank -%}
              <div class="origin-modern-hero__description">{{ section.settings.description }}</div>
            {%- endif -%}

            {%- if section.settings.button_text != blank -%}
              <button class="origin-modern-hero__button" {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}>
                {{ section.settings.button_text | escape }}
              </button>
            {%- endif -%}

            {%- if section.settings.show_rating -%}
              <div class="origin-modern-hero__rating">
                <svg class="origin-modern-hero__rating-icon" width="79" height="15" viewBox="0 0 79 15" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
