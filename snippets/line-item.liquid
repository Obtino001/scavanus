{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
LINE ITEM
----------------------------------------------------------------------------------------------------------------------

This component renders a single line item product information, and is used on order and cart page.

********************************************
Supported variables
********************************************

* line_item: the line item to render (required)
* show_desktop_quantity: if set to true (for instance on cart drawer), the quantity is also shown on the line
{%- endcomment -%}

{% liquid
  assign max_quantity = nil

  if line_item.variant.quantity_rule.max != nil
    assign max_quantity = max_quantity | default: 999999 | at_most: line_item.variant.quantity_rule.max
  endif
%}

{%- capture remove_icon -%}
  <svg width="23" height="23" viewBox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M9.104 13.8958L9.104 11.0208" stroke="#333333" stroke-linecap="round"/>
    <path d="M13.896 13.8958L13.896 11.0208" stroke="#333333" stroke-linecap="round"/>
    <path d="M2.875 6.22916H20.125C18.7791 6.22916 18.1061 6.22916 17.6227 6.55217C17.4134 6.69201 17.2337 6.8717 17.0938 7.08098C16.7708 7.56441 16.7708 8.23738 16.7708 9.58332V14.8542C16.7708 16.6612 16.7708 17.5647 16.2095 18.1261C15.6481 18.6875 14.7446 18.6875 12.9375 18.6875H10.0625C8.25545 18.6875 7.35192 18.6875 6.79055 18.1261C6.22917 17.5647 6.22917 16.6612 6.22917 14.8542V9.58332C6.22917 8.23738 6.22917 7.56441 5.90615 7.08098C5.76631 6.8717 5.58662 6.69201 5.37734 6.55217C4.89391 6.22916 4.22094 6.22916 2.875 6.22916Z" stroke="#333333" stroke-linecap="round"/>
    <path d="M9.10433 3.35441C9.10433 3.35441 9.5835 2.39584 11.5002 2.39584C13.4168 2.39584 13.896 3.35418 13.896 3.35418" stroke="#333333" stroke-linecap="round"/>
  </svg>
{%- endcapture -%}

{%- capture decrease_icon -%}
  <svg width="7" height="1" viewBox="0 0 7 1" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M0 0.5H7" stroke="black"/>
  </svg>
{%- endcapture -%}

{%- capture increase_icon -%}
  <svg width="7" height="7" viewBox="0 0 7 7" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M0 3.495H7" stroke="black"/>
    <path d="M3.50488 0L3.50488 7" stroke="black"/>
  </svg>
{%- endcapture -%}

<line-item class="line-item">
  {%- if line_item.image != blank -%}
    <div class="line-item__media-wrapper">
      {{- line_item.image | image_url: width: line_item.image.width | image_tag: loading: 'lazy', sizes: '(max-width: 740px) 80px, 96px', widths: '80,96,160,192', class: 'line-item__media rounded-xs' -}}

      <pill-loader class="pill-loader"></pill-loader>
    </div>
  {%- endif -%}

  <div class="line-item__info">
    <div class="v-stack gap-0.5">
      {%- if line_item.url != blank -%}
        <a href="{{ line_item.url }}" class="bold">
          <span class="reversed-link hover:show">{{ line_item.product.title | default: line_item.title }}</span>
        </a>
      {%- else -%}
        <p class="bold">{{ line_item.product.title | default: line_item.title }}</p>
      {%- endif -%}

      {%- render 'price-list', line_item: line_item -%}
    </div>

    {%- unless line_item.product.has_only_default_variant or line_item.gift_card -%}
      <p class="text-sm text-subdued">{{ line_item.variant.title }}</p>
    {%- endunless -%}

    {%- if line_item.selling_plan_allocation -%}
      <p class="text-sm text-subdued">{{ line_item.selling_plan_allocation.selling_plan.name }}</p>
    {%- endif -%}

    {%- unless line_item.properties == blank -%}
      <ul class="list-disc">
        {%- for property in line_item.properties -%}
          {%- assign first_character_in_key = property.first | truncate: 1, '' -%}

          {%- if property.last == blank or first_character_in_key == '_' -%}
            {%- continue -%}
          {%- endif -%}

          <li class="text-sm text-subdued">
            {%- if property.last contains '/uploads/' or property.last contains '/files/' -%}
              <a href="{{ property.last }}" class="link">{{ property.last | split: '/' | last }}</a>
            {%- else -%}
              {{ property.first }}: {{ property.last }}
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endunless -%}

    <div class="text-sm text-subdued sm:hidden" style="width: 100%;">
      {%- if line_item.url_to_remove -%}
        <line-item-quantity class="line-item__quantity-row">
          <div class="line-item__quantity-control">
            <button type="button" class="line-item__quantity-button" data-quantity-action="decrease" aria-label="{{ 'cart.order.decrease_quantity' | t | escape }}">
              {{- decrease_icon -}}
            </button>
            <input class="quantity-input line-item__quantity-input" type="number" is="quantity-input" inputmode="numeric" min="{{ line_item.variant.quantity_rule.min }}" step="{{ line_item.variant.quantity_rule.increment }}" {% if max_quantity != nil %}max="{{ max_quantity }}"{% endif %} data-line-key="{{ line_item.key }}" aria-label="{{ 'cart.order.change_quantity' | t | escape }}" value="{{ line_item.quantity }}">
            <button type="button" class="line-item__quantity-button" data-quantity-action="increase" aria-label="{{ 'cart.order.increase_quantity' | t | escape }}">
              {{- increase_icon -}}
            </button>
          </div>

          <a href="{{ line_item.url_to_remove }}" class="line-item__remove-button" aria-label="{{ 'cart.order.remove_with_title' | t: title: line_item.title | escape }}">
            {{- remove_icon -}}
          </a>
        </line-item-quantity>
      {%- else -%}
        {{- 'customer.order.quantity' | t }}: {{ line_item.quantity -}}
      {%- endif -%}
    </div>

    {%- if line_item.line_level_discount_allocations != blank -%}
      <ul class="contents" role="list">
        {%- for discount_allocation in line_item.line_level_discount_allocations -%}
          <li class="badge">
            {%- render 'icon' with 'discount' -%} {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})

            {%- if section.settings.allow_discount_application and discount_allocation.discount_application.type != '' -%}
              <cart-discount-remove-button discount-code="{{ discount_allocation.discount_application.title | escape }}" class="h-stack align-center">
                <button type="button">{%- render 'icon' with 'delete', width: 8, stroke_width: 3 -%}</button>
              </cart-discount-remove-button>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {%- if show_desktop_quantity -%}
    <div class="line-item__actions text-subdued hidden sm:block">
      <line-item-quantity class="line-item__quantity-row">
        <div class="line-item__quantity-control">
          <button type="button" class="line-item__quantity-button" data-quantity-action="decrease" aria-label="{{ 'cart.order.decrease_quantity' | t | escape }}">
            {{- decrease_icon -}}
          </button>
          <input class="quantity-input line-item__quantity-input" type="number" is="quantity-input" inputmode="numeric" min="{{ line_item.variant.quantity_rule.min }}" step="{{ line_item.variant.quantity_rule.increment }}" {% if max_quantity != nil %}max="{{ max_quantity }}"{% endif %} data-line-key="{{ line_item.key }}" aria-label="{{ 'cart.order.change_quantity' | t | escape }}" value="{{ line_item.quantity }}">
          <button type="button" class="line-item__quantity-button" data-quantity-action="increase" aria-label="{{ 'cart.order.increase_quantity' | t | escape }}">
            {{- increase_icon -}}
          </button>
        </div>

        <a href="{{ line_item.url_to_remove }}" class="line-item__remove-button" aria-label="{{ 'cart.order.remove_with_title' | t: title: line_item.title | escape }}">
          {{- remove_icon -}}
        </a>
      </line-item-quantity>
    </div>
  {%- endif -%}
</line-item>